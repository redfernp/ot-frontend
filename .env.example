# Staging WordPress WPGraphQL endpoint.
WPGRAPHQL_ENDPOINT=https://staging.example.com/graphql

# Optional, only if staging WordPress is protected by HTTP basic auth.
WP_BASIC_AUTH_USER=
WP_BASIC_AUTH_PASSWORD=

# Public frontend URL for canonical construction. Set to the live domain
# (https://www.oddstips.co.uk) even on staging so canonicals point at production.
# If the staging preview URL ever gets indexed, the canonical tells search engines
# it's a duplicate of the live page.
PUBLIC_SITE_URL=https://www.oddstips.co.uk

# GA4 measurement ID (G-XXXXXXX). Optional. When set, BaseLayout includes the
# gtag.js snippet site-wide and the affiliate cloak at /go/{slug}/ fires an
# affiliate_click event before redirecting. When unset, the site works fine
# but no analytics events are collected.
PUBLIC_GA4_ID=

