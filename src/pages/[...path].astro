---
import BaseLayout from "@/layouts/BaseLayout.astro";
import CategoryTipsPage from "@/components/CategoryTipsPage.astro";
import FootballHubPage from "@/components/FootballHubPage.astro";
import GenericPage from "@/components/GenericPage.astro";
import TennisHubPage from "@/components/TennisHubPage.astro";
import TipPostPage from "@/components/TipPostPage.astro";
import { getCategory, getPage, getPost, getRelatedPosts, type WpPost } from "@/lib/graphql";

// SSR this route at the Cloudflare edge. Tip posts, categories, and generic
// WP pages all render on demand. The live WP backend publishes new tip posts
// every ~5 minutes via cron; static rebuilds cannot keep up, so this route
// stays dynamic with a 5-minute edge cache (max-age + s-maxage) and a
// 24-hour stale-while-revalidate so already-visited URLs survive a WP outage.
//
// See HANDOFF.md Phase 7 for the architectural rationale.
export const prerender = false;

const simpleSportHubSlugs = new Set(["tennis", "cricket", "snooker", "darts", "basketball"]);

// Path resolver: figure out what kind of WP content lives at the requested
// URL.
//   - Multi-segment paths (e.g. football/united-kingdom/england-premier-league)
//     or known sport hub top-levels (football, tennis, ...) are categories.
//   - Single-segment paths could be a tip post slug OR a generic WP page slug,
//     so query both in parallel and prefer whichever resolves.
//   - Anything that does not resolve returns a 404.
const rawPath = (Astro.params.path || "").replace(/^\/+|\/+$/g, "");
const segments = rawPath.split("/").filter(Boolean);

if (segments.length === 0) {
  return new Response(null, { status: 404 });
}

const firstSegment = segments[0];
const lastSegment = segments[segments.length - 1];
const looksLikeCategory =
  segments.length >= 2 || firstSegment === "football" || simpleSportHubSlugs.has(firstSegment);

let category = null;
let post: WpPost | null = null;
let page: WpPost | null = null;
let relatedPosts: WpPost[] = [];
let categorySlug = "";

if (looksLikeCategory) {
  categorySlug = lastSegment;
  category = await getCategory(categorySlug, 100).catch(() => null);

  if (!category) {
    return new Response(null, { status: 404 });
  }
} else {
  const slug = firstSegment;
  const pageUri = `/${slug}/`;

  // Race a post lookup against a page lookup. First non-null wins. If WP is
  // momentarily unreachable both come back null and we 404; the edge cache
  // serves prior visitors from stale-while-revalidate.
  const [postResult, pageResult] = await Promise.all([
    getPost(slug).catch(() => null),
    getPage(pageUri).catch(() => null),
  ]);

  if (postResult) {
    post = postResult;
    relatedPosts = await getRelatedPosts(post).catch(() => []);
  } else if (pageResult) {
    page = pageResult;
  } else {
    return new Response(null, { status: 404 });
  }
}

// Edge cache headers. Cloudflare honours these for Worker responses and will
// keep the rendered HTML on the edge for 5 minutes (matching the WP cron
// cadence), serving stale-while-revalidate for up to a day after that so an
// outage on the WP backend cannot break URLs that have been visited at least
// once.
Astro.response.headers.set(
  "Cache-Control",
  "public, max-age=300, s-maxage=300, stale-while-revalidate=86400",
);
---

<BaseLayout
  title={page?.title || post?.title || `${category?.name || "Category"} Betting Tips`}
  description={page?.seo?.metaDesc || post?.excerpt || category?.description || ""}
  seo={page?.seo || post?.seo || category?.seo}
>
  {page ? (
    <GenericPage page={page} />
  ) : post ? (
    <TipPostPage post={post} relatedPosts={relatedPosts} />
  ) : category && categorySlug === "football" ? (
    <FootballHubPage category={category} />
  ) : category && simpleSportHubSlugs.has(categorySlug) ? (
    <TennisHubPage category={category} />
  ) : (
    category && <CategoryTipsPage category={category} />
  )}
</BaseLayout>
