---
const destination = "/free-bets/";
---

<!doctype html>
<html lang="en-GB">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="robots" content="noindex, follow" />
    <meta http-equiv="refresh" content={`0;url=${destination}`} />
    <title>Review no longer available - Oddstips</title>
    <link rel="canonical" href={destination} />
  </head>
  <body>
    <main>
      <h1>Review no longer available</h1>
      <p>This bookmaker review is no longer available on Oddstips.</p>
      <p><a href={destination}>Compare current bookmaker offers</a>.</p>
    </main>
  </body>
</html>
