---
import BaseLayout from "@/layouts/BaseLayout.astro";
import BookmakerReviewPage from "@/components/BookmakerReviewPage.astro";
import { bookmakers } from "@/lib/bookmakers";
import { publicSiteOrigin } from "@/lib/cmsContent";

export function getStaticPaths() {
  return Object.entries(bookmakers).map(([slug, bookmaker]) => ({
    params: { slug },
    props: { bookmaker },
  }));
}

const { bookmaker } = Astro.props;
const canonical = `${publicSiteOrigin()}/reviews/${bookmaker.slug}/`;
---

<BaseLayout
  title={`${bookmaker.brand} Review (May 2026) - ${bookmaker.bonus.headline} - Oddstips`}
  description={`In-depth ${bookmaker.brand} review: welcome offer, odds quality, markets, banking and verdict. Updated for May 2026.`}
  canonical={canonical}
>
  <BookmakerReviewPage bookmaker={bookmaker} />
</BaseLayout>
