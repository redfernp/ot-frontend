---

<BaseLayout
  title="Best Free Bets and Bookmaker Sign-Up Offers (May 2026) - Oddstips"
  description="Compare current bookmaker free bet and bonus offers, with the exact promotional terms shown directly under every offer headline."
>
  <nav class="breadcrumbs" aria-label="Breadcrumb">
    <a href="/">Home</a> <span class="sep">/</span> <span aria-current="page">Free Bets</span>
  </nav>

  <section class="hero" aria-labelledby="hero-heading">
    <div>
      <p class="eyebrow">Updated {lastUpdated}</p>
      <h1 id="hero-heading">Best free bets and bookmaker sign-up offers</h1>
      <p class="lede">
        Compare the headline deal, exact ad terms, qualifying action and expiry in one place. Pick the offer that
        fits how you actually bet, then open the bookmaker when you are ready.
      </p>
      <ul class="hero-points">
        <li><span class="check">v</span> Covering all markets and bet types</li>
        <li><span class="check">v</span> Reward, qualifying action and expiry shown clearly</li>
        <li><span class="check">v</span> Fast comparison across current bookmaker offers</li>
      </ul>
    </div>
    <aside class="hero-side" aria-label="Quick stats">
      <div><strong>{offers.length}</strong><span>Offers compared</span></div>
      <div><strong>All</strong><span>Market types covered</span></div>
      <div><strong>Quick</strong><span>Offer value check</span></div>
    </aside>
  </section>

  <section class="comparison" aria-labelledby="compare-heading">
    <div class="section-head">
      <h2 id="compare-heading">Compare free bet offers</h2>
      <p>Start with the headline offer, read the exact terms, then use the CTA if the deal fits.</p>
    </div>
    <div class="offer-grid">
      {offers.map((offer) => (
        <article class="offer-card" id={offer.slug} style={`--offer-bg:${offer.color}`}>
          <div class="offer-card-inner">
            <header class="offer-card-head">
              <img class="bookmaker-logo" src={offer.logoSrc} alt={`${offer.brand} logo`} decoding="async" />
              <span class="stars" aria-label="Five star bookmaker rating">★★★★★</span>
              <a class="review-link" href={offer.reviewHref} rel="nofollow noopener" target="_blank">
                {offer.brand} Review
              </a>
            </header>

            <h3>{offer.headline}</h3>

            <p class="terms">{offer.terms}</p>

            <p class="offer-description">
              <span class="check-mark" aria-hidden="true">✓</span>
              <span>{offer.description}</span>
            </p>

            <a class="cta" href={offer.offerHref} rel="nofollow sponsored noopener" target="_blank">{offer.cta}</a>

            <dl class="offer-meta">
              <div>
                <dt>Customer</dt>
                <dd>{offer.customer}</dd>
              </div>
              <div>
                <dt>Qualifying action</dt>
                <dd>{offer.qualifying}</dd>
              </div>
              <div>
                <dt>Reward</dt>
                <dd>{offer.reward}</dd>
              </div>
              <div>
                <dt>Expiry</dt>
                <dd>{offer.expiry}</dd>
              </div>
            </dl>
          </div>
        </article>
      ))}
    </div>
  </section>

  <section class="how-we-rate" aria-labelledby="how-heading">
    <h2 id="how-heading">How to choose a free bet offer</h2>
    <div class="rate-grid">
      {howWeRate.map((item) => (
        <div class="rate-card">
          <h3>{item.title}</h3>
          <p>{item.text}</p>
        </div>
      ))}
    </div>
  </section>

  <section class="faqs" aria-labelledby="faq-heading">
    <h2 id="faq-heading">Free bet FAQs</h2>
    <div class="faq-list">
      {faqs.map((faq) => (
        <details>
          <summary>{faq.q}</summary>
          <p>{faq.a}</p>
        </details>
      ))}
    </div>
  </section>

  <section class="responsible-band">
    <strong>We respect responsible gambling.</strong>
    <p>Compare the value first, choose offers that fit your normal betting style, and only bet what you are comfortable with.</p>
  </section>
</BaseLayout>

<style>
  .breadcrumbs { color: var(--ot-muted); font-size: 0.85rem; margin-bottom: 1rem; }
  .breadcrumbs a { color: var(--ot-ink-2); text-decoration: none; }
  .breadcrumbs .sep { color: var(--ot-muted-2); margin: 0 0.35rem; }

  .hero {
    background: linear-gradient(135deg, #052e1c 0%, #0d4a30 60%, #167447 100%);
    border-radius: var(--ot-radius);
    color: #fff;
    display: grid;
    gap: 1rem;
    grid-template-columns: 1.4fr 1fr;
    margin-bottom: 1.5rem;
    overflow: hidden;
  }
  .hero > div { padding: 2.25rem; }
  .hero h1 { color: #fff; max-width: 22ch; }
  .hero .eyebrow { color: var(--ot-gold); }
  .lede { color: #c9efd9; font-size: 1.05rem; margin: 0 0 1.25rem; max-width: 56ch; }
  .hero-points { color: #d8f0e1; display: grid; gap: 0.4rem; font-weight: 700; list-style: none; margin: 0; padding: 0; }
  .check {
    background: var(--ot-gold);
    border-radius: 999px;
    color: var(--ot-ink);
    display: inline-block;
    font-size: 0.7rem;
    font-weight: 900;
    height: 18px;
    line-height: 18px;
    margin-right: 0.4rem;
    text-align: center;
    width: 18px;
  }
  .hero-side {
    background: rgba(255,255,255,0.06);
    border-left: 1px solid rgba(255,255,255,0.14);
    display: grid;
    gap: 0;
    grid-template-rows: repeat(3, 1fr);
  }
  .hero-side div { border-bottom: 1px solid rgba(255,255,255,0.1); padding: 1.25rem; }
  .hero-side div:last-child { border-bottom: 0; }
  .hero-side strong { color: #fff; display: block; font-size: 1.7rem; }
  .hero-side span { color: #c9efd9; font-size: 0.78rem; letter-spacing: 0.08em; text-transform: uppercase; }
  @media (max-width: 880px) {
    .hero { grid-template-columns: 1fr; }
    .hero-side { border-left: 0; border-top: 1px solid rgba(255,255,255,0.14); }
  }

  .section-head {
    align-items: end;
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    justify-content: space-between;
    margin-bottom: 1rem;
  }
  .section-head h2, .section-head p { margin: 0; }
  .section-head p { color: var(--ot-muted); }

  /* COMPARISON */
  .comparison { margin-top: 2rem; }
  .offer-grid {
    display: grid;
    gap: 1rem;
    grid-template-columns: repeat(auto-fit, minmax(min(100%, 330px), 1fr));
  }

  .offer-card {
    background: var(--offer-bg);
    color: #fff;
    min-width: 0;
  }

  .offer-card-inner {
    display: grid;
    gap: 1.1rem;
    min-width: 0;
    padding: 1.65rem;
    text-align: center;
  }

  .offer-card-head {
    align-items: center;
    display: grid;
    gap: 0.45rem;
    justify-items: center;
  }

  .bookmaker-logo {
    display: block;
    height: 52px;
    max-width: min(230px, 86%);
    object-fit: contain;
    width: auto;
  }

  .stars {
    color: #ffc928;
    font-size: 1.28rem;
    letter-spacing: 0.08em;
    line-height: 1;
  }

  .review-link {
    color: #fff;
    font-size: 0.9rem;
    font-weight: 800;
    text-decoration: underline;
    text-underline-offset: 3px;
  }
  .review-link:hover { color: #ffe2c7; }

  .offer-card h3 {
    color: #fff;
    font-size: clamp(1.35rem, 2.1vw, 1.65rem);
    line-height: 1.15;
    margin: 0.2rem 0 0;
    overflow-wrap: anywhere;
  }

  .offer-description {
    align-items: center;
    color: #fff;
    display: flex;
    font-size: 0.98rem;
    font-weight: 700;
    gap: 0.75rem;
    justify-content: center;
    line-height: 1.55;
    margin: 0;
    min-width: 0;
  }

  .offer-description span:last-child {
    min-width: 0;
    overflow-wrap: anywhere;
  }

  .check-mark {
    color: #fff;
    flex: 0 0 auto;
    font-size: 1.55rem;
    font-weight: 900;
    line-height: 1;
  }

  .cta {
    background: var(--ot-brand-orange);
    border-radius: 6px;
    box-shadow: 0 4px 10px rgba(0, 0, 0, 0.18);
    color: #fff;
    display: block;
    font-size: 1.15rem;
    font-weight: 900;
    justify-self: center;
    max-width: 100%;
    min-width: min(280px, 100%);
    padding: 0.9rem 1.35rem;
    text-decoration: none;
  }
  .cta:hover { background: #d95800; }

  .terms {
    color: #fff;
    font-size: 0.84rem;
    font-weight: 600;
    line-height: 1.25;
    margin: 0;
    overflow-wrap: anywhere;
    text-wrap: pretty;
  }

  .offer-meta {
    background: rgba(255, 255, 255, 0.12);
    border: 1px solid rgba(255, 255, 255, 0.2);
    display: grid;
    gap: 0;
    grid-template-columns: 1fr 1fr;
    margin: 0;
    text-align: left;
  }

  .offer-meta div {
    border-bottom: 1px solid rgba(255, 255, 255, 0.16);
    min-width: 0;
    padding: 0.75rem;
  }

  .offer-meta div:nth-child(odd) {
    border-right: 1px solid rgba(255, 255, 255, 0.16);
  }

  .offer-meta div:nth-last-child(-n+2) {
    border-bottom: 0;
  }

  .offer-meta dt {
    color: rgba(255, 255, 255, 0.76);
    font-size: 0.64rem;
    font-weight: 900;
    letter-spacing: 0.08em;
    margin: 0 0 0.25rem;
    text-transform: uppercase;
  }

  .offer-meta dd {
    color: #fff;
    font-size: 0.84rem;
    font-weight: 800;
    line-height: 1.3;
    margin: 0;
    overflow-wrap: anywhere;
  }

  @media (max-width: 720px) {
    .offer-grid {
      grid-template-columns: 1fr;
    }
    .offer-card-inner {
      padding: 1.45rem 1.15rem;
    }
    .bookmaker-logo { height: 48px; }
    .offer-description {
      align-items: flex-start;
      text-align: left;
    }
    .offer-meta {
      grid-template-columns: 1fr;
    }
    .offer-meta div,
    .offer-meta div:nth-child(odd),
    .offer-meta div:nth-last-child(-n+2) {
      border-bottom: 1px solid rgba(255, 255, 255, 0.16);
      border-right: 0;
    }
    .offer-meta div:last-child {
      border-bottom: 0;
    }
  }

  /* HOW WE RATE */
  .how-we-rate { margin-top: 2.5rem; }
  .rate-grid { display: grid; gap: 1rem; grid-template-columns: repeat(4, 1fr); }
  .rate-card {
    background: var(--ot-surface);
    border: 1px solid var(--ot-border);
    border-radius: var(--ot-radius);
    padding: 1.25rem;
  }
  .rate-card h3 { font-size: 1rem; margin: 0 0 0.5rem; }
  .rate-card p { color: var(--ot-text-2); margin: 0; }
  @media (max-width: 880px) { .rate-grid { grid-template-columns: 1fr 1fr; } }
  @media (max-width: 540px) { .rate-grid { grid-template-columns: 1fr; } }

  .faqs { margin-top: 2.5rem; }
  .faq-list { display: grid; gap: 0.5rem; }
  details {
    background: var(--ot-surface);
    border: 1px solid var(--ot-border);
    border-radius: var(--ot-radius-sm);
