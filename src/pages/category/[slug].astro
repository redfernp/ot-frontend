---
import BaseLayout from "@/layouts/BaseLayout.astro";
import PostCard from "@/components/PostCard.astro";
import { getCategories, getCategory } from "@/lib/graphql";
import { placeholderCategory, placeholderPost } from "@/lib/placeholders";

export async function getStaticPaths() {
  const categories = await getCategories(20);

  if (!categories.length) {
    return [{ params: { slug: placeholderCategory.slug } }];
  }

  return categories.map((category) => ({
    params: { slug: category.slug },
  }));
}

const { slug } = Astro.params;
const category = (slug ? await getCategory(slug) : null) || {
  ...placeholderCategory,
  posts: { nodes: [placeholderPost] },
};
const posts = category.posts?.nodes ?? [];
---

<BaseLayout
  title={`${category.name || "Category"} Betting Tips`}
  description={category.description || "Category page proof of concept."}
  seo={category.seo}
>
  <section class="panel">
    <p class="eyebrow">Category template</p>
    <h1>{category.name || "Category"}</h1>
    {category.description && <p set:html={category.description} />}
  </section>

  <section class="panel category-value">
    <h2>Future ACF Category Modules</h2>
    <p>
      This area will become the high-value user section: featured bookmaker offers, comparison tables, FAQs,
      category-specific guidance, and today’s best tips.
    </p>
  </section>

  <section>
    <h2>Latest Tips</h2>
    <div class="grid">
      {posts.length ? posts.map((post) => <PostCard post={post} />) : <PostCard post={placeholderPost} />}
    </div>
  </section>
</BaseLayout>

<style>
  .eyebrow {
    color: #2563eb;
    font-size: 0.875rem;
    font-weight: 800;
    margin: 0 0 0.5rem;
    text-transform: uppercase;
  }

  section + section {
    margin-top: 2rem;
  }

  .category-value {
    background: #eef6ff;
  }
</style>
