---
import Seo from "@/components/Seo.astro";
import StagingBanner from "@/components/StagingBanner.astro";
import type { SeoFields } from "@/lib/graphql";

type Props = {
  title?: string;
  description?: string;
  canonical?: string;
  seo?: SeoFields;
};

const { title, description, canonical, seo } = Astro.props;

type NavItem = {
  label: string;
  href: string;
  featured?: boolean;
  external?: boolean;
  children?: Array<{ label: string; href: string; external?: boolean }>;
};

// Mirrors the live oddstips.co.uk top nav. Free Bets stays first as the featured gold
// pill. "More Sports" and "About" render as click-to-open dropdowns via <details>.
const primaryNav: NavItem[] = [
  { href: "/free-bets/", label: "Free Bets", featured: true },
  { href: "/football/", label: "Football" },
  {
    label: "More Sports",
    href: "#",
    children: [
      { label: "Tennis", href: "/tennis/" },
      { label: "Cricket", href: "/cricket/" },
      { label: "Basketball", href: "/basketball/" },
      { label: "Darts", href: "/darts/" },
    ],
  },
  {
    label: "About",
    href: "/about/",
    children: [
      { label: "Safer Gambling", href: "/safer-gambling/" },
    ],
  },
  {
    label: "Pro Football Tips",
    href: "/go/footballer-tips-tipstrr/",
    external: true,
  },
];

// GA4 measurement ID. Set PUBLIC_GA4_ID in Cloudflare Pages env (e.g. G-XXXXXXX).
// When unset (e.g. in dev), the gtag snippet is omitted entirely and the
// affiliate cloak in src/pages/go/[slug].astro falls through to its hard
// 1-second redirect fallback.
const ga4Id = import.meta.env.PUBLIC_GA4_ID;
---

<!doctype html>
<html lang="en-GB">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <Seo title={title} description={description} canonical={canonical} seo={seo} />
    {ga4Id && (
      <>
        <script is:inline async src={`https://www.googletagmanager.com/gtag/js?id=${ga4Id}`}></script>
        <script is:inline define:vars={{ ga4Id }}>
          window.dataLayer = window.dataLayer || [];
          function gtag() { dataLayer.push(arguments); }
          gtag("js", new Date());
          gtag("config", ga4Id);
          window.gtag = gtag;
        </script>
      </>
    )}
  </head>
  <body>
    <StagingBanner />

    <header class="site-header">
      <input class="nav-toggle" type="checkbox" id="ot-nav-toggle" aria-hidden="true" />
      <div class="header-inner">
        <a class="brand" href="/">
          <span class="brand-mark" aria-hidden="true">OT</span>
          <span class="brand-text">
            <strong>Oddstips</strong>
          </span>
        </a>

        <nav class="primary-nav" aria-label="Primary">
          {primaryNav.map((item) => (
            item.children && item.children.length > 0 ? (
              <details class="nav-dropdown">
                <summary>
                  <span>{item.label}</span>
                  <svg class="chev" viewBox="0 0 24 24" width="12" height="12" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                    <path d="m6 9 6 6 6-6" />
                  </svg>
                </summary>
                <div class="nav-dropdown-panel">
                  {item.children.map((child) => (
                    <a
                      href={child.href}
                      {...(child.external ? { rel: "nofollow noopener", target: "_blank" } : {})}
                    >
                      {child.label}
                    </a>
                  ))}
                </div>
              </details>
            ) : (
              <a
                href={item.href}
                class:list={{ "is-featured": item.featured }}
                {...(item.external ? { rel: "nofollow noopener", target: "_blank" } : {})}
              >
                {item.featured && <span class="featured-dot" aria-hidden="true"></span>}
                {item.label}
              </a>
            )
          ))}
        </nav>

        <label class="nav-burger" for="ot-nav-toggle" aria-label="Open menu" tabindex="0" role="button">
          <span class="burger-bars" aria-hidden="true">
            <span></span>
            <span></span>
            <span></span>
          </span>
        </label>
      </div>
      <label class="nav-scrim" for="ot-nav-toggle" aria-hidden="true"></label>
    </header>

    <main>
      <slot />
    </main>

    <footer class="site-footer">
      <div class="footer-grid">
        <div>
          <p class="footer-title">Oddstips</p>
          <p class="footer-blurb">
            Free betting tips, bookmaker reviews and value picks across football, tennis, cricket and more.
          </p>
        </div>
        <div>
          <p class="footer-title">Sports</p>
          <ul>
            <li><a href="/football/">Football</a></li>
            <li><a href="/tennis/">Tennis</a></li>
            <li><a href="/cricket/">Cricket</a></li>
            <li><a href="/snooker/">Snooker</a></li>
            <li><a href="/darts/">Darts</a></li>
            <li><a href="/basketball/">Basketball</a></li>
          </ul>
        </div>
        <div>
          <p class="footer-title">Leagues</p>
          <ul>
            <li><a href="/football/united-kingdom/england-premier-league/">Premier League</a></li>
            <li><a href="/football/spain-la-liga/">La Liga</a></li>
            <li><a href="/football/italy-serie-a/">Serie A</a></li>
            <li><a href="/football/uefa-champions-league/">Champions League</a></li>
          </ul>
        </div>
        <div>
          <p class="footer-title">Help</p>
          <ul>
            <li><a href="/free-bets/">Free bets</a></li>
            <li><a href="/reviews/">Bookmaker reviews</a></li>
            <li><a href="/about/">About</a></li>
            <li><a href="/responsible-gambling/">Responsible gambling</a></li>
          </ul>
        </div>
      </div>

      <div class="footer-band">
        <p>Here at oddstips.co.uk, we understand that gambling can become an addiction that can cause great harm if not controlled. We respectfully remind you that you should only ever bet with an amount of money that you can afford to lose. The information provided on site at oddstips.co.uk, is for information and entertainment purposes only, and Oddstips will not be held liable for any inaccuracy, or for any loss which may be incurred. For help regarding a gambling addiction, or more information on the subject, please visit: <a href="https://www.gambleaware.org/" rel="nofollow noopener" target="_blank">www.gambleaware.org</a>. 18+ only. You can also read our <a href="/safer-gambling/">safer gambling guide</a> for more information.</p>
        <p>Advertising disclosure: Every online gambler deserves a trusted, and fair place to play. At oddstips.co.uk, we offer free, impartial and independent reviews of the UK's best online betting operators so that you can play with confidence and security. All ratings and reviews are made independently of the operator by our team of gaming experts with years of gaming experience. We only review companies that are fully UK licensed. meaning have passed the most stringent of player safety tests as laid out by the UK Gambling Commission, therefore can be trusted to offer fair play, and have independent betting adjudication services to also assist player complaints when customers and operators fail to meet satisfactory conclusion to a players complaint. We accept compensation from the companies advertised on this website via their affiliate program and this may affect the brand positioning.</p>
        <p>Copyright 2024 - OddsTips.co.uk | <a href="/terms-of-service/">Terms Of Service</a> | <a href="/privacy/">Privacy</a> | <a href="/contact/">Contact Us</a> | <a href="https://www.gambleaware.org/" rel="nofollow noopener" target="_blank">GambleAware</a> | <a href="/safer-gambling/">Safer Gambling</a> | 18+</p>
      </div>
    </footer>
  </body>
</html>

<style is:global>
  :root {
    /* Brand */
    --ot-ink: #0b1f3f;
    --ot-ink-2: #102f67;
    --ot-gold: #d8ad55;
    --ot-green: #0f766e;
    --ot-green-2: #027b5b;
    --ot-danger: #b91c1c;

    /* Oddstips live-site brand (used selectively, e.g. tip body sections) */
    --ot-brand-blue: #1e73be;
    --ot-brand-blue-dark: #1c67ab;
    --ot-brand-blue-soft: #afc8df;
    --ot-brand-blue-muted: #5f91bf;
    --ot-brand-orange: #f56300;
    --ot-brand-orange-soft: #fde2cc;

    /* Surfaces */
    --ot-bg: #f5f7fb;
    --ot-surface: #ffffff;
    --ot-surface-2: #f8fafc;
    --ot-border: #e1e7ef;
    --ot-border-strong: #d7dde6;

    /* Text */
    --ot-text: #101828;
    --ot-text-2: #344054;
    --ot-muted: #5d697a;
    --ot-muted-2: #8a94a6;

    /* Effects */
    --ot-shadow-sm: 0 1px 2px rgba(11, 31, 63, 0.04), 0 1px 1px rgba(11, 31, 63, 0.03);
    --ot-shadow-md: 0 4px 12px rgba(11, 31, 63, 0.06);
    --ot-radius: 10px;
    --ot-radius-sm: 6px;

    color-scheme: light;
    font-family: Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
    line-height: 1.5;
    color: var(--ot-text);
    background: var(--ot-bg);
  }

  * { box-sizing: border-box; }

  body {
    margin: 0;
    min-height: 100vh;
  }

  a { color: var(--ot-ink-2); }

  main {
    margin: 0 auto;
    max-width: 1200px;
    padding: 1.25rem 1rem 2.5rem;
  }

  /* HEADER */
  .site-header {
    background: linear-gradient(180deg, var(--ot-ink) 0%, #0a1e3d 100%);
    color: #fff;
    position: sticky;
    top: 0;
    z-index: 30;
  }

  .header-inner {
    align-items: center;
    display: grid;
    gap: 1.25rem;
    grid-template-columns: auto 1fr auto;
    margin: 0 auto;
    max-width: 1200px;
    padding: 0.85rem 1rem;
  }

  .brand {
    align-items: center;
    color: #fff;
    display: flex;
    gap: 0.65rem;
    text-decoration: none;
  }

  .brand-mark {
    align-items: center;
    background: var(--ot-gold);
    border-radius: 8px;
    color: var(--ot-ink);
    display: inline-flex;
    font-weight: 900;
    height: 36px;
    justify-content: center;
    letter-spacing: 0.04em;
    width: 36px;
  }

  .brand-text {
    display: flex;
    flex-direction: column;
    line-height: 1.1;
  }

  .brand-text strong {
    color: #fff;
    font-size: 1.1rem;
    letter-spacing: 0.01em;
  }

  .brand-text small {
    color: #c5d2ea;
    font-size: 0.7rem;
    font-weight: 600;
    letter-spacing: 0.05em;
    text-transform: uppercase;
  }

  .primary-nav {
    display: flex;
    flex-wrap: wrap;
    gap: 0.25rem 1.1rem;
    justify-content: center;
  }

  .primary-nav a {
    color: #d5e0f4;
    font-size: 0.9rem;
    font-weight: 700;
    padding: 0.45rem 0.1rem;
    position: relative;
    text-decoration: none;
  }

  .primary-nav a:hover {
    color: var(--ot-gold);
  }

  .primary-nav a.is-featured {
    align-items: center;
    background: var(--ot-gold);
    border-radius: 999px;
    color: var(--ot-ink);
    display: inline-flex;
    font-size: 0.85rem;
    font-weight: 900;
    gap: 0.4rem;
    padding: 0.45rem 0.95rem;
  }
  .primary-nav a.is-featured:hover {
    background: #e7bc60;
    color: var(--ot-ink);
  }
  .featured-dot {
    background: var(--ot-danger);
    border-radius: 999px;
    box-shadow: 0 0 0 3px rgba(185, 28, 28, 0.18);
    display: inline-block;
    height: 8px;
    width: 8px;
  }

  /* DROPDOWN NAV ITEMS */
  .nav-dropdown {
    position: relative;
  }
  .nav-dropdown > summary {
    align-items: center;
    color: #d5e0f4;
    cursor: pointer;
    display: inline-flex;
    font-size: 0.9rem;
    font-weight: 700;
    gap: 0.3rem;
    list-style: none;
    padding: 0.45rem 0.1rem;
  }
  .nav-dropdown > summary::-webkit-details-marker { display: none; }
  .nav-dropdown > summary:hover { color: var(--ot-gold); }
  .nav-dropdown .chev {
    transition: transform 180ms ease;
  }
  .nav-dropdown[open] > summary { color: var(--ot-gold); }
  .nav-dropdown[open] > summary .chev { transform: rotate(180deg); }

  .nav-dropdown-panel {
    background: var(--ot-surface);
    border: 1px solid var(--ot-border);
    border-radius: var(--ot-radius);
    box-shadow: 0 12px 30px rgba(11, 31, 63, 0.18);
    display: grid;
    left: -0.5rem;
    margin-top: 0.5rem;
    min-width: 200px;
    overflow: hidden;
    padding: 0.3rem 0;
    position: absolute;
    top: 100%;
    z-index: 40;
  }
  .nav-dropdown-panel a {
    color: var(--ot-brand-blue);
    font-size: 0.9rem;
    font-weight: 600;
    padding: 0.6rem 1rem;
    text-decoration: none;
    transition: background 100ms ease, color 100ms ease;
  }
  .nav-dropdown-panel a:hover {
    background: #f3f8fd;
    color: var(--ot-brand-blue-dark);
  }

  /* HAMBURGER (mobile only) */
  .nav-toggle {
    clip: rect(0 0 0 0);
    clip-path: inset(50%);
    height: 1px;
    overflow: hidden;
    position: absolute;
    white-space: nowrap;
    width: 1px;
  }
  .nav-burger:focus-visible {
    outline: 2px solid var(--ot-gold);
    outline-offset: 2px;
  }
  .nav-burger {
    align-items: center;
    background: rgba(255, 255, 255, 0.08);
    border: 1px solid rgba(255, 255, 255, 0.18);
    border-radius: 10px;
    cursor: pointer;
    display: none;
    height: 40px;
    justify-content: center;
    transition: background 160ms ease;
    width: 44px;
  }
  .nav-burger:hover { background: rgba(255, 255, 255, 0.16); }
  .burger-bars {
    display: flex;
    flex-direction: column;
    gap: 5px;
    height: 14px;
    justify-content: center;
    width: 20px;
  }
  .burger-bars span {
    background: #fff;
    border-radius: 2px;
    height: 2px;
    transform-origin: center;
    transition: transform 220ms cubic-bezier(0.2, 0.8, 0.2, 1), opacity 180ms ease;
    width: 100%;
  }
  .nav-toggle:checked ~ .header-inner .burger-bars span:nth-child(1) {
    transform: translateY(7px) rotate(45deg);
  }
  .nav-toggle:checked ~ .header-inner .burger-bars span:nth-child(2) {
    opacity: 0;
    transform: scaleX(0);
  }
  .nav-toggle:checked ~ .header-inner .burger-bars span:nth-child(3) {
    transform: translateY(-7px) rotate(-45deg);
  }
  .nav-scrim {
    background: rgba(11, 31, 63, 0.55);
    cursor: pointer;
    inset: 0;
    opacity: 0;
    pointer-events: none;
    position: fixed;
    transition: opacity 220ms ease;
    z-index: 28;
  }
  .nav-toggle:checked ~ .nav-scrim {
    opacity: 1;
    pointer-events: auto;
  }

  @media (max-width: 880px) {
    .header-inner {
      display: flex;
      gap: 0.5rem;
      justify-content: space-between;
    }
    .brand { margin-right: auto; }
    .nav-burger {
      display: inline-flex;
      margin-left: auto;
    }
    .primary-nav {
      background: linear-gradient(180deg, var(--ot-ink-2) 0%, var(--ot-ink) 100%);
      border-radius: 18px 0 0 18px;
      box-shadow: -16px 0 40px rgba(11, 31, 63, 0.45);
      flex-direction: column;
      gap: 0;
      height: 100vh;
      justify-content: flex-start;
      padding: 5.5rem 1.5rem 2rem;
      position: fixed;
      right: 0;
      top: 0;
      transform: translateX(100%);
      transition: transform 280ms cubic-bezier(0.2, 0.8, 0.2, 1);
      width: min(82vw, 320px);
      z-index: 29;
    }
    .primary-nav a {
      border-bottom: 1px solid rgba(255, 255, 255, 0.08);
      color: #fff;
      font-size: 1rem;
      padding: 1rem 0.25rem;
      width: 100%;
    }
    .primary-nav a:hover { color: var(--ot-gold); }
    .primary-nav a.is-featured {
      background: var(--ot-gold);
      border-bottom: 0;
      border-radius: 12px;
      color: var(--ot-ink);
      font-size: 1.05rem;
      justify-content: center;
      margin-bottom: 1rem;
      padding: 1rem 1.1rem;
      width: 100%;
    }
    .primary-nav a.is-featured:hover {
      background: #e7bc60;
      color: var(--ot-ink);
    }

    /* Mobile: dropdowns expand inline inside the drawer */
    .nav-dropdown {
      border-bottom: 1px solid rgba(255, 255, 255, 0.08);
      width: 100%;
    }
    .nav-dropdown > summary {
      color: #fff;
      font-size: 1rem;
      justify-content: space-between;
      padding: 1rem 0.25rem;
      width: 100%;
    }
    .nav-dropdown-panel {
      background: rgba(255, 255, 255, 0.04);
      border: 0;
      border-radius: 0;
      box-shadow: none;
      margin-bottom: 0.5rem;
      margin-top: 0;
      padding: 0.2rem 0 0.5rem;
      position: static;
    }
    .nav-dropdown-panel a {
      border-bottom: 0;
      color: #d5e0f4;
      font-size: 0.95rem;
      font-weight: 600;
      padding: 0.6rem 1rem;
      width: 100%;
    }
    .nav-dropdown-panel a:hover {
      background: rgba(255, 255, 255, 0.05);
      color: var(--ot-gold);
    }

    .nav-toggle:checked ~ .header-inner .primary-nav {
      transform: translateX(0);
    }
    body:has(.nav-toggle:checked) { overflow: hidden; }
  }

  /* FOOTER */
  .site-footer {
    background: var(--ot-ink);
    color: #c5d2ea;
    margin-top: 3rem;
    padding: 2.5rem 1rem 1.5rem;
  }

  .footer-grid {
    display: grid;
    gap: 2rem;
    grid-template-columns: 1.4fr repeat(3, 1fr);
    margin: 0 auto;
    max-width: 1200px;
  }

  .footer-title {
    color: #fff;
    font-size: 0.85rem;
    font-weight: 800;
    letter-spacing: 0.08em;
    margin: 0 0 0.85rem;
    text-transform: uppercase;
  }

  .footer-blurb {
    color: #aab8d3;
    font-size: 0.92rem;
    line-height: 1.55;
    margin: 0;
    max-width: 36ch;
  }

  .site-footer ul {
    display: grid;
    gap: 0.5rem;
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .site-footer a {
    color: #d5e0f4;
    font-size: 0.92rem;
    text-decoration: none;
  }

  .site-footer a:hover { color: var(--ot-gold); }

  .footer-band {
    border-top: 1px solid rgba(255, 255, 255, 0.12);
    color: #8aa0c8;
    display: grid;
    font-size: 0.76rem;
    gap: 0.85rem;
    line-height: 1.6;
    margin: 2rem auto 0;
    max-width: 1200px;
    padding-top: 1.5rem;
  }
  .footer-band p { margin: 0; }
  .footer-band a {
    color: #d5e0f4;
    font-size: inherit;
    text-decoration: underline;
    text-underline-offset: 2px;
  }
  .footer-band a:hover { color: var(--ot-gold); }

  @media (max-width: 720px) {
    .footer-grid { grid-template-columns: 1fr 1fr; }
  }

  /* TYPOGRAPHY */
  h1, h2, h3, p { letter-spacing: 0; }

  h1 {
    font-size: clamp(1.85rem, 5vw, 2.85rem);
    line-height: 1.08;
    margin: 0 0 1rem;
  }

  h2 {
    font-size: 1.45rem;
    line-height: 1.2;
    margin: 0 0 1rem;
  }

  /* UTILITY */
  .panel {
    background: var(--ot-surface);
    border: 1px solid var(--ot-border);
    border-radius: var(--ot-radius);
    box-shadow: var(--ot-shadow-sm);
    padding: 1.25rem;
  }

  .eyebrow {
    color: var(--ot-green);
    font-size: 0.78rem;
    font-weight: 900;
    letter-spacing: 0.08em;
    margin: 0 0 0.5rem;
    text-transform: uppercase;
  }

  .grid {
    display: grid;
    gap: 1rem;
    grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
  }
</style>
