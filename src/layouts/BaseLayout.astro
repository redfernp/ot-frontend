---
import Seo from "@/components/Seo.astro";
import StagingBanner from "@/components/StagingBanner.astro";
import type { SeoFields } from "@/lib/graphql";

type Props = {
  title?: string;
  description?: string;
  canonical?: string;
  seo?: SeoFields;
};

const { title, description, canonical, seo } = Astro.props;
---

<!doctype html>
<html lang="en-GB">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <Seo title={title} description={description} canonical={canonical} seo={seo} />
  </head>
  <body>
    <StagingBanner />
    <header class="site-header">
      <a class="brand" href="/">Oddstips</a>
      <nav aria-label="Primary">
        <a href="/category/example/">Categories</a>
        <a href="/free-bets/">Free Bets</a>
      </nav>
    </header>
    <main>
      <slot />
    </main>
    <footer class="site-footer">
      <p>Oddstips staging frontend proof of concept.</p>
    </footer>
  </body>
</html>

<style is:global>
  :root {
    color-scheme: light;
    font-family: Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
    line-height: 1.5;
    color: #172033;
    background: #f5f7fb;
  }

  * {
    box-sizing: border-box;
  }

  body {
    margin: 0;
    min-height: 100vh;
  }

  a {
    color: #174ea6;
  }

  .site-header,
  .site-footer {
    align-items: center;
    display: flex;
    gap: 1rem;
    justify-content: space-between;
    margin: 0 auto;
    max-width: 1180px;
    padding: 1rem;
  }

  .site-header nav {
    display: flex;
    gap: 1rem;
  }

  .brand {
    color: #101828;
    font-size: 1.25rem;
    font-weight: 800;
    text-decoration: none;
  }

  main {
    margin: 0 auto;
    max-width: 1180px;
    padding: 1rem;
  }

  .panel {
    background: #fff;
    border: 1px solid #d7dde6;
    border-radius: 8px;
    padding: 1.25rem;
  }

  .grid {
    display: grid;
    gap: 1rem;
    grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
  }

  h1,
  h2,
  h3,
  p {
    letter-spacing: 0;
  }

  h1 {
    font-size: clamp(2rem, 6vw, 3.5rem);
    line-height: 1.05;
    margin: 0 0 1rem;
  }

  h2 {
    font-size: 1.5rem;
    line-height: 1.2;
    margin: 0 0 1rem;
  }

  .site-footer {
    color: #667085;
    font-size: 0.875rem;
  }
</style>
