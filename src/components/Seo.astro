---
import type { SeoFields } from "@/lib/graphql";
import { rewriteCmsLink } from "@/lib/cmsContent";

type Props = {
  title?: string;
  description?: string;
  canonical?: string;
  seo?: SeoFields;
  noindex?: boolean;
};

// Default to indexable for go-live. Pages that need explicit noindex can
// still opt in by passing noindex={true} (e.g. /go/{slug}/ cloaks already
// set their own robots meta directly).
const { title, description, canonical, seo, noindex = false } = Astro.props;
const pageTitle = seo?.title || title || "Oddstips";
const pageDescription = seo?.metaDesc || description;
const canonicalUrl = rewriteCmsLink(seo?.canonical || canonical);
const ogImage = rewriteCmsLink(seo?.opengraphImage?.sourceUrl);
---

<title>{pageTitle}</title>
{pageDescription && <meta name="description" content={pageDescription} />}
{canonicalUrl && <link rel="canonical" href={canonicalUrl} />}
{noindex && <meta name="robots" content="noindex,nofollow" />}
<meta property="og:title" content={seo?.opengraphTitle || pageTitle} />
{(seo?.opengraphDescription || pageDescription) && (
  <meta property="og:description" content={seo?.opengraphDescription || pageDescription} />
)}
{ogImage && <meta property="og:image" content={ogImage} />}
<meta name="twitter:card" content={seo?.opengraphImage?.sourceUrl ? "summary_large_image" : "summary"} />
<meta name="twitter:title" content={seo?.twitterTitle || seo?.opengraphTitle || pageTitle} />
{(seo?.twitterDescription || seo?.opengraphDescription || pageDescription) && (
  <meta name="twitter:description" content={seo?.twitterDescription || seo?.opengraphDescription || pageDescription} />
)}
