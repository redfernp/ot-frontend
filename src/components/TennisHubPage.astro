---
import CouponRow from "@/components/CouponRow.astro";
import CategorySidebar from "@/components/CategorySidebar.astro";
import DateRail from "@/components/DateRail.astro";
import HubHero from "@/components/HubHero.astro";
import type { WpCategory, WpPost } from "@/lib/graphql";
import { placeholderTennisTips } from "@/lib/relatedTips";
import { getCategorySeoCopy } from "@/lib/categorySeoCopy";

// Simple sport hub mirrors the football hub layout without country or league blocks.
// SEO text comes from ACF Pro category_top_seo_text + category_bottom_seo_text.
type CategoryWithSeo = WpCategory & {
  posts?: { nodes: WpPost[] };
  categoryTopSeoText?: {
    categoryTopSeoTextEditor?: string;
  };
  categoryBottomSeoText?: {
    categoryBottomSeoText?: string;
  };
};

type Props = {
  category: CategoryWithSeo;
};

const { category } = Astro.props;
const hasWpGraphQL = Boolean(import.meta.env.WPGRAPHQL_ENDPOINT);
const livePosts = category.posts?.nodes ?? [];
const fallbackPosts = category.slug === "tennis" ? placeholderTennisTips : [];
const posts = livePosts.length ? livePosts : hasWpGraphQL ? [] : fallbackPosts;

const fallbackSeo = getCategorySeoCopy(category.slug);
const topSeo = category.categoryTopSeoText?.categoryTopSeoTextEditor || fallbackSeo.top || "";
const bottomSeo = category.categoryBottomSeoText?.categoryBottomSeoText || fallbackSeo.bottom || "";

const categoryName = category.name || "Sport";
const sportLabel = categoryName.toLowerCase();

const heroLede =
  topSeo ||
  `<p>Today's best ${sportLabel} predictions, scored through Oddstips' 38-section value algorithm. Scan the picks below or jump straight into a match.</p>`;
---

<nav class="breadcrumbs" aria-label="Breadcrumb">
  <a href="/">Home</a>
  <span class="sep">/</span>
  <span aria-current="page">{categoryName}</span>
</nav>

<HubHero
  eyebrow={`${categoryName} match betting`}
  heading={`${categoryName} Betting Tips`}
  ledeHtml={heroLede}
/>

<div class="hub-layout">
  <main class="hub-main">
    <DateRail />

    <section class="post-list sport-list" aria-labelledby="latest-sport-heading" data-date-filter-section>
      <header class="post-list-head">
        <p class="eyebrow on-orange">{categoryName} tips</p>
        <h2 id="latest-sport-heading">{categoryName} Predictions</h2>
        <p class="post-list-meta">
          <span data-date-count data-singular="match" data-plural="matches">
            {posts.length} {posts.length === 1 ? "match" : "matches"}
          </span>
        </p>
      </header>
      {posts.length > 0 ? (
        <div class="post-list-rows" data-date-filter-list>
          {posts.map((post) => <CouponRow post={post} />)}
        </div>
      ) : null}
      <p class="empty-state" data-date-empty hidden={posts.length > 0}>No {sportLabel} tips found for this date. Try another date.</p>
    </section>

    {bottomSeo && (
      <section class="seo-content" aria-label="Category guide">
        <div class="seo-prose" set:html={bottomSeo} />
      </section>
    )}
  </main>

  <CategorySidebar currentPath={category.uri} showInternational={false} showPopularLeagues={false} />
</div>

<style>
  .breadcrumbs {
    color: var(--ot-muted);
    font-size: 0.85rem;
    margin-bottom: 1rem;
  }
  .breadcrumbs a { color: var(--ot-brand-blue); text-decoration: none; }
  .breadcrumbs a:hover { text-decoration: underline; }
  .breadcrumbs .sep { color: var(--ot-muted-2); margin: 0 0.35rem; }

  .hub-layout {
    display: grid;
    gap: 1.5rem;
    grid-template-columns: minmax(0, 1fr) 300px;
  }

  .hub-main {
    display: flex;
    flex-direction: column;
    gap: 1.75rem;
    min-width: 0;
  }

  /* POST LIST (matches football post-list pattern) */
  .post-list {
    background: var(--ot-surface);
    border: 1px solid var(--ot-border);
    border-radius: var(--ot-radius);
    box-shadow: var(--ot-shadow-sm);
    overflow: hidden;
  }
  .sport-list { border-top: 4px solid var(--ot-brand-orange); }
  .post-list-head {
    align-items: end;
    background: linear-gradient(180deg, #f3f8fd 0%, #ffffff 100%);
    border-bottom: 1px solid var(--ot-border);
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem 1rem;
    justify-content: space-between;
    padding: 1.1rem 1.25rem;
  }
  .post-list-head .eyebrow {
    color: var(--ot-brand-blue);
    font-size: 0.7rem;
    font-weight: 900;
    letter-spacing: 0.1em;
    margin: 0;
    text-transform: uppercase;
    width: 100%;
  }
  .post-list-head .eyebrow.on-orange { color: var(--ot-brand-orange); }
  .post-list-head h2 {
    color: var(--ot-text);
    font-size: 1.15rem;
    margin: 0.2rem 0 0;
  }
  .post-list-meta {
    color: var(--ot-muted);
    font-size: 0.8rem;
    margin: 0;
  }
  .empty-state {
    color: var(--ot-muted);
    font-size: 0.95rem;
    margin: 0;
    padding: 1.5rem 1.25rem;
  }

  /* SEO CONTENT (matches football SEO content pattern) */
  .seo-content {
    background: var(--ot-surface);
    border: 1px solid var(--ot-border);
    border-radius: var(--ot-radius);
    box-shadow: var(--ot-shadow-sm);
    padding: 1.75rem 1.75rem 2rem;
  }
  .seo-prose {
    color: var(--ot-text);
    font-size: 1rem;
    line-height: 1.7;
    max-width: 70ch;
  }
  .seo-prose :global(h2) {
    border-bottom: 2px solid var(--ot-brand-blue-soft);
    color: var(--ot-brand-blue-dark);
    font-size: 1.25rem;
    margin: 2rem 0 0.85rem;
    padding-bottom: 0.4rem;
  }
  .seo-prose :global(h2:first-child) { margin-top: 0; }
  .seo-prose :global(p) {
    color: var(--ot-text-2);
    margin: 0 0 1rem;
  }
  .seo-prose :global(p:last-child) { margin-bottom: 0; }
  .seo-prose :global(strong) { color: var(--ot-text); }
  .seo-prose :global(a) {
    color: var(--ot-brand-blue);
    font-weight: 700;
    text-decoration: underline;
    text-decoration-color: var(--ot-brand-blue-soft);
    text-underline-offset: 3px;
  }
  .seo-prose :global(a:hover) {
    color: var(--ot-brand-blue-dark);
    text-decoration-color: var(--ot-brand-blue);
  }

  @media (max-width: 880px) {
    .hub-layout { grid-template-columns: 1fr; }
    .seo-content { padding: 1.5rem 1.4rem; }
  }
</style>
