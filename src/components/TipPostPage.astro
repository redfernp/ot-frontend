---
import type { WpPost } from "@/lib/graphql";
import { summarizeTip } from "@/lib/tips";

type Props = {
  post: WpPost;
};

const { post } = Astro.props;
const summary = summarizeTip(post);
const activePick = summary.couponPick;
const published = post.date
  ? new Date(post.date).toLocaleString("en-GB", { dateStyle: "full", timeStyle: "short" })
  : null;
const signals = [
  { label: "Game flow", value: summary.gameFlow },
  { label: "First goal", value: summary.firstGoal },
  { label: "Goal source", value: summary.sourceOfFirstGoal },
  { label: "Injury risk", value: summary.riskOfInjuries },
  { label: "Corners", value: summary.cornerCount },
  { label: "Bookings", value: summary.bookings },
  { label: "Penalties", value: summary.penaltiesAwarded },
  { label: "Key area", value: summary.keyArea },
].filter((signal) => signal.value);
---

<article class="tip-page">
  <section class="tip-hero">
    <div class="match-copy">
      <p class="eyebrow">Fixed odds tip</p>
      <h1>{summary.fixture || post.title || "Betting Tip"}</h1>
      {(summary.homeTeam || summary.awayTeam) && (
        <p class="teams">
          {summary.homeTeam || "Home"} <span>v</span> {summary.awayTeam || "Away"}
        </p>
      )}
      {summary.event && <p class="event">{summary.event}</p>}
    </div>

    <aside class="pick-panel" aria-label="1x2 tip summary">
      <span class="label">OddsTips pick</span>
      <strong>{summary.tip || "View tip details"}</strong>
      <div class="market" aria-label="1x2 market">
        <span class:list={["market-cell", { active: activePick === "H" }]}>
          <b>1</b>
          <small>{summary.homeTeam || "Home"}</small>
        </span>
        <span class:list={["market-cell", { active: activePick === "D" }]}>
          <b>X</b>
          <small>Draw</small>
        </span>
        <span class:list={["market-cell", { active: activePick === "A" }]}>
          <b>2</b>
          <small>{summary.awayTeam || "Away"}</small>
        </span>
      </div>
    </aside>
  </section>

  <section class="summary-strip" aria-label="Tip details">
    <div>
      <span class="label">Kickoff</span>
      <strong>{summary.kickoff || "TBC"}</strong>
    </div>
    <div>
      <span class="label">Bet365 odds</span>
      <strong>{summary.odds || "-"}</strong>
    </div>
    <div>
      <span class="label">Game flow</span>
      <strong>{summary.gameFlow || "TBC"}</strong>
    </div>
    <div>
      <span class="label">Published</span>
      <strong>{published || "TBC"}</strong>
    </div>
  </section>

  <div class="tip-layout">
    <section class="analysis">
      <h2>Match Tip</h2>
      {signals.length > 0 && (
        <div class="signal-grid" aria-label="Match signals">
          {signals.map((signal) => (
            <div>
              <span class="label">{signal.label}</span>
              <strong>{signal.value}</strong>
            </div>
          ))}
        </div>
      )}
      {(summary.returns || summary.value) && (
        <div class="value-card">
          {summary.returns && (
            <div>
              <span class="label">Returns</span>
              <p>{summary.returns}</p>
            </div>
          )}
          {summary.value && (
            <div>
              <span class="label">Value</span>
              <p>{summary.value}</p>
            </div>
          )}
        </div>
      )}
      {post.content ? <div class="content" set:html={post.content} /> : <p set:html={post.excerpt || ""} />}
    </section>

    <aside class="coupon-note" aria-label="Coupon summary">
      <h2>Coupon View</h2>
      <dl>
        <div>
          <dt>Selection</dt>
          <dd>{summary.tip || "TBC"}</dd>
        </div>
        <div>
          <dt>Market</dt>
          <dd>1x2</dd>
        </div>
        <div>
          <dt>Odds</dt>
          <dd>{summary.odds || "-"}</dd>
        </div>
      </dl>
    </aside>
  </div>
</article>

<style>
  .tip-page {
    display: grid;
    gap: 1rem;
  }

  .eyebrow {
    color: #2563eb;
    font-size: 0.875rem;
    font-weight: 800;
    margin: 0 0 0.5rem;
    text-transform: uppercase;
  }

  .tip-hero {
    align-items: stretch;
    background: #fff;
    border: 1px solid #d7dde6;
    border-radius: 8px;
    display: grid;
    gap: 0;
    grid-template-columns: minmax(0, 1.45fr) minmax(320px, 0.85fr);
    overflow: hidden;
  }

  .match-copy,
  .pick-panel {
    padding: 1.25rem;
  }

  .match-copy h1 {
    font-size: clamp(2rem, 4.5vw, 3.2rem);
    line-height: 1.05;
    margin: 0;
  }

  .teams {
    color: #172033;
    font-size: 1.1rem;
    font-weight: 800;
    margin: 1rem 0 0;
  }

  .teams span {
    color: #778397;
    font-size: 0.86rem;
    padding: 0 0.4rem;
    text-transform: uppercase;
  }

  .event {
    color: #667085;
    font-size: 1rem;
    margin: 0.75rem 0 0;
    max-width: 64ch;
  }

  .pick-panel {
    background: #f1f8f6;
    border-left: 1px solid #b9ddd5;
    display: flex;
    flex-direction: column;
    justify-content: center;
  }

  .label {
    color: #5d697a;
    display: block;
    font-size: 0.75rem;
    font-weight: 800;
    letter-spacing: 0;
    margin-bottom: 0.35rem;
    text-transform: uppercase;
  }

  .pick-panel > strong {
    color: #0f766e;
    font-size: 1.35rem;
    line-height: 1.2;
    margin-bottom: 1rem;
  }

  .market {
    display: grid;
    gap: 0.45rem;
    grid-template-columns: repeat(3, minmax(0, 1fr));
  }

  .market-cell {
    align-items: center;
    background: #fff;
    border: 1px solid #cfd8e6;
    border-radius: 6px;
    color: #3f4d5f;
    display: flex;
    flex-direction: column;
    gap: 0.18rem;
    justify-content: center;
    min-height: 4.25rem;
    min-width: 0;
    padding: 0.55rem 0.35rem;
    text-align: center;
  }

  .market-cell.active {
    background: #12233d;
    border-color: #12233d;
    color: #fff;
  }

  .market-cell b {
    font-size: 1.25rem;
    line-height: 1;
  }

  .market-cell small {
    font-size: 0.75rem;
    font-weight: 800;
    line-height: 1.1;
    max-width: 100%;
    overflow-wrap: anywhere;
  }

  .summary-strip {
    background: #fff;
    border: 1px solid #d7dde6;
    border-radius: 8px;
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    overflow: hidden;
  }

  .summary-strip div {
    border-right: 1px solid #e4e9f1;
    min-width: 0;
    padding: 1rem;
  }

  .summary-strip div:last-child {
    border-right: 0;
  }

  .summary-strip strong {
    color: #101828;
    display: block;
    font-size: 0.98rem;
    line-height: 1.3;
  }

  .tip-layout {
    align-items: start;
    display: grid;
    gap: 1rem;
    grid-template-columns: minmax(0, 1fr) minmax(260px, 0.34fr);
  }

  .analysis,
  .coupon-note {
    background: #fff;
    border: 1px solid #d7dde6;
    border-radius: 8px;
    padding: 1.25rem;
  }

  .analysis h2,
  .coupon-note h2 {
    margin-top: 0;
  }

  .signal-grid {
    display: grid;
    gap: 0.65rem;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    margin-bottom: 1rem;
  }

  .signal-grid div {
    background: #f8fafc;
    border: 1px solid #e1e7ef;
    border-radius: 8px;
    min-width: 0;
    padding: 0.85rem;
  }

  .signal-grid strong {
    color: #101828;
    display: block;
    font-size: 0.98rem;
    line-height: 1.25;
  }

  .value-card {
    background: #f1f8f6;
    border: 1px solid #b9ddd5;
    border-radius: 8px;
    display: grid;
    gap: 0.85rem;
    margin-bottom: 1.2rem;
    padding: 1rem;
  }

  .value-card p {
    color: #233044;
    font-weight: 700;
    margin: 0;
  }

  .coupon-note {
    position: sticky;
    top: 1rem;
  }

  .coupon-note dl {
    display: grid;
    gap: 0.9rem;
    margin: 0;
  }

  .coupon-note div {
    border-bottom: 1px solid #e4e9f1;
    padding-bottom: 0.9rem;
  }

  .coupon-note div:last-child {
    border-bottom: 0;
    padding-bottom: 0;
  }

  .coupon-note dt {
    color: #667085;
    font-size: 0.8rem;
    font-weight: 800;
    margin-bottom: 0.25rem;
    text-transform: uppercase;
  }

  .coupon-note dd {
    color: #101828;
    font-size: 1rem;
    font-weight: 800;
    margin: 0;
  }

  .content :global(img) {
    height: auto;
    max-width: 100%;
  }

  .content :global(h2),
  .content :global(h3) {
    border-top: 1px solid #e4e9f1;
    font-size: 1.12rem;
    margin: 1.35rem 0 0.5rem;
    padding-top: 1.1rem;
  }

  .content :global(h2:first-child),
  .content :global(h3:first-child) {
    border-top: 0;
    margin-top: 0;
    padding-top: 0;
  }

  .content :global(p) {
    color: #344054;
    margin: 0 0 0.85rem;
  }

  @media (max-width: 860px) {
    .tip-hero,
    .tip-layout,
    .summary-strip {
      grid-template-columns: 1fr;
    }

    .pick-panel {
      border-left: 0;
      border-top: 1px solid #b9ddd5;
    }

    .summary-strip div {
      border-bottom: 1px solid #e4e9f1;
      border-right: 0;
    }

    .summary-strip div:last-child {
      border-bottom: 0;
    }

    .coupon-note {
      position: static;
    }

    .signal-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (max-width: 520px) {
    .market {
      grid-template-columns: 1fr;
    }

    .signal-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
