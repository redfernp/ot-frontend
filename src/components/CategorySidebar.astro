---
import { getMenu } from "@/lib/graphql";
import { cmsLinkToPath } from "@/lib/cmsContent";

type Props = {
  showPopularLeagues?: boolean;
  showInternational?: boolean;
  currentPath?: string;
};

const { showPopularLeagues = true, showInternational = true, currentPath } = Astro.props;

// Pull menus from WordPress (Appearance > Menus). Slugs are auto-generated from
// the menu name; they must stay in sync with WP. The getMenu helper caches the
// fetch per slug across the build so each menu only hits WPGraphQL once.
const popularLeaguesMenu = showPopularLeagues ? await getMenu("popular-leagues") : null;
const internationalMenu = showInternational ? await getMenu("international-games") : null;

type SidebarLink = { label: string; path: string };

function menuToLinks(menu: Awaited<ReturnType<typeof getMenu>>): SidebarLink[] {
  if (!menu) return [];

  return menu.menuItems
    .map((item) => ({
      label: (item.label ?? "").trim(),
      path: cmsLinkToPath(item.url) ?? "",
    }))
    .filter((link) => link.label && link.path);
}

const popularLeaguesLinks = menuToLinks(popularLeaguesMenu);
const internationalLinks = menuToLinks(internationalMenu);
---

<aside class="cat-sidebar" aria-label="League navigation">
  <section class="sidebar-offer" aria-label="Bet365 free bet offer">
    <p class="offer-kicker">#Ad &middot; New customers</p>
    <h2>Bet &pound;10 &amp; Get &pound;30 in Free Bets</h2>
    <a class="offer-cta" href="/go/bet365/" rel="nofollow sponsored noopener" target="_blank">
      Claim with Bet365
    </a>
    <p class="offer-terms">
      #Ad - Bet &pound;10 &amp; Get &pound;30 in Free Bets for new customers at bet365. Min deposit requirement. Free Bets are paid as Bet Credits and are available for use upon settlement of bets to value of qualifying deposit. Min odds, bet and payment method exclusions apply. Returns exclude Bet Credits stake. Time limits and T&amp;Cs apply. Registration required.
    </p>
    <p class="offer-safe">18+ &middot; BeGambleAware.org &middot; GamCare.org.uk</p>
  </section>

  <form class="sidebar-search" role="search" action="/" method="get">
    <label class="sr-only" for="cat-search">Search latest free tips</label>
    <input
      id="cat-search"
      type="search"
      name="s"
      placeholder="Search latest free tips"
      autocomplete="off"
    />
    <button type="submit" aria-label="Search">
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <circle cx="11" cy="11" r="7" />
        <path d="m21 21-4.3-4.3" />
      </svg>
    </button>
  </form>

  {showPopularLeagues && popularLeaguesLinks.length > 0 && (
    <div class="sidebar-block">
      <p class="sidebar-eyebrow">{popularLeaguesMenu?.name || "Popular Leagues"}</p>
      <ul>
        {popularLeaguesLinks.map((link) => (
          <li>
            <a href={link.path} class:list={{ "is-current": currentPath === link.path }}>
              {link.label}
            </a>
          </li>
        ))}
      </ul>
    </div>
  )}

  {showInternational && internationalLinks.length > 0 && (
    <div class="sidebar-block">
      <p class="sidebar-eyebrow">{internationalMenu?.name || "International Games"}</p>
      <ul>
        {internationalLinks.map((link) => (
          <li>
            <a href={link.path} class:list={{ "is-current": currentPath === link.path }}>
              {link.label}
            </a>
          </li>
        ))}
      </ul>
    </div>
  )}

  <p class="sidebar-be">18+ &middot; Please gamble responsibly. BeGambleAware.org</p>
</aside>

<style>
  .cat-sidebar {
    align-content: start;
    align-self: start;
    display: grid;
    gap: 1rem;
  }

  .sr-only {
    clip: rect(0 0 0 0);
    clip-path: inset(50%);
    height: 1px;
    overflow: hidden;
    position: absolute;
    white-space: nowrap;
    width: 1px;
  }

  .sidebar-offer {
    background: #047a35;
    border-radius: var(--ot-radius);
    box-shadow: var(--ot-shadow-sm);
    color: #fff;
    display: grid;
    gap: 0.9rem;
    padding: 1.25rem;
  }
  .offer-kicker {
    align-self: start;
    background: rgba(255, 255, 255, 0.16);
    border-radius: 999px;
    color: #fff;
    display: inline-flex;
    font-size: 0.72rem;
    font-weight: 900;
    justify-self: start;
    letter-spacing: 0.05em;
    line-height: 1;
    margin: 0;
    padding: 0.45rem 0.7rem;
    text-transform: uppercase;
  }
  .sidebar-offer h2 {
    color: #fff;
    font-size: 1.25rem;
    line-height: 1.15;
    margin: 0;
  }
  .offer-cta {
    background: var(--ot-gold);
    border-radius: 999px;
    color: var(--ot-ink);
    display: block;
    font-size: 0.98rem;
    font-weight: 900;
    padding: 0.85rem 1rem;
    text-align: center;
    text-decoration: none;
  }
  .offer-cta:hover {
    background: #e7bc60;
    color: var(--ot-ink);
  }
  .offer-terms {
    color: rgba(255, 255, 255, 0.92);
    font-size: 0.78rem;
    font-weight: 600;
    line-height: 1.45;
    margin: 0;
  }
  .offer-safe {
    color: rgba(255, 255, 255, 0.72);
    font-size: 0.74rem;
    font-weight: 700;
    margin: 0;
  }

  .sidebar-search {
    background: var(--ot-surface);
    border: 1px solid var(--ot-border);
    border-radius: var(--ot-radius);
    box-shadow: var(--ot-shadow-sm);
    display: flex;
    min-height: 44px;
    overflow: hidden;
  }
  .sidebar-search input {
    background: transparent;
    border: 0;
    color: var(--ot-text);
    flex: 1;
    font: inherit;
    font-size: 0.84rem;
    min-width: 0;
    padding: 0.55rem 0.75rem;
  }
  .sidebar-search input:focus { outline: 2px solid var(--ot-brand-blue-soft); outline-offset: -2px; }
  .sidebar-search button {
    background: var(--ot-brand-blue);
    border: 0;
    color: #fff;
    cursor: pointer;
    flex: 0 0 46px;
    padding: 0;
    transition: background 120ms ease;
  }
  .sidebar-search button:hover { background: var(--ot-brand-blue-dark); }

  .sidebar-block {
    background: var(--ot-surface);
    border: 1px solid var(--ot-border);
    border-radius: var(--ot-radius);
    box-shadow: var(--ot-shadow-sm);
    overflow: hidden;
  }
  .sidebar-eyebrow {
    background: var(--ot-brand-blue);
    color: #fff;
    font-size: 0.72rem;
    font-weight: 900;
    letter-spacing: 0.1em;
    margin: 0;
    padding: 0.7rem 1rem;
    text-transform: uppercase;
  }
  .sidebar-block ul {
    list-style: none;
    margin: 0;
    padding: 0.25rem 0;
  }
  .sidebar-block li + li {
    border-top: 1px solid var(--ot-border);
  }
  .sidebar-block a {
    color: var(--ot-brand-blue);
    display: block;
    font-size: 0.9rem;
    font-weight: 600;
    padding: 0.65rem 1rem;
    text-decoration: none;
    transition: background 100ms ease, color 100ms ease;
  }
  .sidebar-block a:hover {
    background: #f3f8fd;
    color: var(--ot-brand-blue-dark);
  }
  .sidebar-block a.is-current {
    background: #fff6ee;
    border-left: 3px solid var(--ot-brand-orange);
    color: var(--ot-brand-orange);
    padding-left: calc(1rem - 3px);
  }

  .sidebar-be {
    color: var(--ot-muted);
    font-size: 0.74rem;
    margin: 0.25rem 0 0;
    text-align: center;
  }
</style>
