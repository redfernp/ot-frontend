---
import type { WpPost } from "@/lib/graphql";
import { summarizeTip } from "@/lib/tips";

type Props = {
  heading?: string;
  posts: WpPost[];
};

const { heading = "All England Premier League Predictions", posts } = Astro.props;

function formatKickoff(dateIso?: string) {
  if (!dateIso) {
    return null;
  }

  const date = new Date(dateIso);

  if (Number.isNaN(date.getTime())) {
    return null;
  }

  return date.toLocaleTimeString("en-GB", { hour: "2-digit", minute: "2-digit", hour12: false });
}
---

{posts.length > 0 && (
  <section class="related-tips" aria-labelledby="related-tips-heading">
    <div class="related-heading">
      <p class="eyebrow">League hub</p>
      <h2 id="related-tips-heading">{heading}</h2>
      <a href="/football/united-kingdom/england-premier-league/">England Premier League hub</a>
    </div>

    <div class="related-list">
      {posts.map((post) => {
        const summary = summarizeTip(post);
        const href = post.uri || `/${post.slug}/`;
        const kickoff = formatKickoff(post.date);

        return (
          <a class="related-card" href={href}>
            {kickoff && <span class="related-kickoff">{kickoff}</span>}
            <span class="related-fixture">{summary.fixture || post.title || "Football tip"}</span>
            <small>View 1x2 tip &rarr;</small>
          </a>
        );
      })}
    </div>
  </section>
)}

<style>
  .related-tips {
    background: var(--ot-surface);
    border: 1px solid var(--ot-border);
    border-radius: var(--ot-radius);
    box-shadow: var(--ot-shadow-sm);
    padding: 1.5rem;
  }

  .related-heading {
    align-items: end;
    border-bottom: 1px solid var(--ot-border);
    display: flex;
    gap: 1rem;
    justify-content: space-between;
    margin-bottom: 1rem;
    padding-bottom: 0.85rem;
  }

  .eyebrow {
    color: var(--ot-brand-blue);
    font-size: 0.72rem;
    font-weight: 900;
    letter-spacing: 0.1em;
    margin: 0 0 0.3rem;
    text-transform: uppercase;
  }

  .related-heading h2 {
    color: var(--ot-text);
    font-size: 1.3rem;
    margin: 0;
  }

  .related-heading a {
    color: var(--ot-brand-blue);
    font-size: 0.88rem;
    font-weight: 800;
    text-align: right;
    text-decoration: none;
  }
  .related-heading a:hover {
    color: var(--ot-brand-blue-dark);
    text-decoration: underline;
  }

  .related-list {
    display: grid;
    gap: 0.6rem;
    grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
  }

  .related-card {
    align-items: center;
    background: var(--ot-surface-2);
    border: 1px solid var(--ot-border);
    border-left: 3px solid var(--ot-brand-blue-soft);
    border-radius: var(--ot-radius-sm);
    color: var(--ot-text);
    display: grid;
    gap: 0.15rem 0.75rem;
    grid-template-columns: auto 1fr;
    padding: 0.7rem 0.9rem;
    text-decoration: none;
    transition: border-color 120ms ease, transform 120ms ease;
  }
  .related-card:hover {
    border-left-color: var(--ot-brand-orange);
    transform: translateX(2px);
  }

  .related-kickoff {
    background: var(--ot-brand-blue);
    border-radius: 4px;
    color: #fff;
    font-size: 0.72rem;
    font-weight: 900;
    grid-row: 1 / span 2;
    letter-spacing: 0.04em;
    padding: 0.3rem 0.45rem;
    text-align: center;
  }

  .related-fixture {
    color: var(--ot-text);
    font-size: 0.92rem;
    font-weight: 800;
    line-height: 1.25;
  }

  .related-card small {
    color: var(--ot-brand-orange);
    font-size: 0.74rem;
    font-weight: 800;
  }

  @media (max-width: 680px) {
    .related-heading {
      align-items: start;
      display: grid;
    }
    .related-heading a {
      text-align: left;
    }
    .related-list {
      grid-template-columns: 1fr;
    }
  }
</style>
