---
import type { WpPost } from "@/lib/graphql";
import { summarizeTip } from "@/lib/tips";

type Props = {
  heading?: string;
  posts: WpPost[];
};

const { heading = "More tips from this league weekend", posts } = Astro.props;
---

{posts.length > 0 && (
  <section class="related-tips" aria-labelledby="related-tips-heading">
    <div class="related-heading">
      <p class="eyebrow">League hub</p>
      <h2 id="related-tips-heading">{heading}</h2>
      <a href="/football/united-kingdom/england-premier-league/">England Premier League hub</a>
    </div>

    <div class="related-list">
      {posts.map((post) => {
        const summary = summarizeTip(post);
        const href = post.uri || `/${post.slug}/`;

        return (
          <a class="related-card" href={href}>
            <span>{summary.fixture || post.title || "Football tip"}</span>
            <small>View 1x2 tip</small>
          </a>
        );
      })}
    </div>
  </section>
)}

<style>
  .related-tips {
    background: #fff;
    border: 1px solid #d7dde6;
    border-radius: 8px;
    padding: 1.25rem;
  }

  .related-heading {
    align-items: end;
    display: flex;
    gap: 1rem;
    justify-content: space-between;
    margin-bottom: 1rem;
  }

  .eyebrow {
    color: #2563eb;
    font-size: 0.75rem;
    font-weight: 900;
    margin: 0 0 0.25rem;
    text-transform: uppercase;
  }

  .related-heading h2 {
    font-size: 1.35rem;
    margin: 0;
  }

  .related-heading a {
    color: #0f766e;
    font-size: 0.9rem;
    font-weight: 800;
    text-align: right;
  }

  .related-list {
    display: grid;
    gap: 0.65rem;
    grid-template-columns: repeat(2, minmax(0, 1fr));
  }

  .related-card {
    background: #f8fafc;
    border: 1px solid #e1e7ef;
    border-radius: 8px;
    color: #101828;
    display: grid;
    gap: 0.35rem;
    min-height: 82px;
    padding: 0.85rem;
    text-decoration: none;
  }

  .related-card span {
    font-weight: 900;
    line-height: 1.3;
  }

  .related-card small {
    color: #0f766e;
    font-weight: 800;
  }

  @media (max-width: 680px) {
    .related-heading {
      align-items: start;
      display: grid;
    }

    .related-heading a {
      text-align: left;
    }

    .related-list {
      grid-template-columns: 1fr;
    }
  }
</style>
