---
type Props = {
  label?: string;
  daysBefore?: number;
  daysAfter?: number;
};

const {
  label = "Match date selector",
  daysBefore = 28,
  daysAfter = 6,
} = Astro.props;

function londonTodayIso() {
  const parts = new Intl.DateTimeFormat("en-GB", {
    day: "2-digit",
    month: "2-digit",
    timeZone: "Europe/London",
    year: "numeric",
  }).formatToParts(new Date());
  const values = Object.fromEntries(parts.map((part) => [part.type, part.value]));

  return `${values.year}-${values.month}-${values.day}`;
}

function addDays(isoDate: string, offset: number) {
  const [year, month, day] = isoDate.split("-").map(Number);
  const date = new Date(Date.UTC(year, month - 1, day + offset));
  const y = date.getUTCFullYear();
  const m = String(date.getUTCMonth() + 1).padStart(2, "0");
  const d = String(date.getUTCDate()).padStart(2, "0");

  return `${y}-${m}-${d}`;
}

function dateLabel(isoDate: string, offset: number) {
  if (offset === -1) {
    return "Yesterday";
  }

  if (offset === 0) {
    return "Today";
  }

  if (offset === 1) {
    return "Tomorrow";
  }

  return new Intl.DateTimeFormat("en-GB", {
    timeZone: "UTC",
    weekday: "short",
  }).format(new Date(`${isoDate}T00:00:00Z`));
}

function shortDate(isoDate: string) {
  return new Intl.DateTimeFormat("en-GB", {
    day: "2-digit",
    month: "short",
    timeZone: "UTC",
  }).format(new Date(`${isoDate}T00:00:00Z`));
}

const today = londonTodayIso();
const items = Array.from({ length: daysBefore + daysAfter + 1 }, (_, index) => {
  const offset = index - daysBefore;
  const isoDate = addDays(today, offset);

  return {
    offset,
    isoDate,
    label: dateLabel(isoDate, offset),
    caption: shortDate(isoDate),
  };
});
---

<nav
  class="date-rail"
  aria-label={label}
  data-date-rail
  data-days-before={daysBefore}
  data-days-after={daysAfter}
>
  <div class="date-list">
    {items.map((item) => (
      <button
        type="button"
        class:list={["date-item", { active: item.offset === 0 }]}
        data-date-link
        data-date-offset={item.offset}
        data-date={item.isoDate}
        aria-current={item.offset === 0 ? "date" : undefined}
      >
        <strong>{item.label}</strong>
        <span>{item.caption}</span>
      </button>
    ))}
  </div>
</nav>

<script is:inline>
  (() => {
    if (window.__otDateRailReady) {
      return;
    }

    window.__otDateRailReady = true;

    const isoPattern = /^\d{4}-\d{2}-\d{2}$/;

    function londonTodayIso() {
      const parts = new Intl.DateTimeFormat("en-GB", {
        day: "2-digit",
        month: "2-digit",
        timeZone: "Europe/London",
        year: "numeric",
      }).formatToParts(new Date());
      const values = Object.fromEntries(parts.map((part) => [part.type, part.value]));

      return `${values.year}-${values.month}-${values.day}`;
    }

    function addDays(isoDate, offset) {
      const [year, month, day] = isoDate.split("-").map(Number);
      const date = new Date(Date.UTC(year, month - 1, day + offset));
      const y = date.getUTCFullYear();
      const m = String(date.getUTCMonth() + 1).padStart(2, "0");
      const d = String(date.getUTCDate()).padStart(2, "0");

      return `${y}-${m}-${d}`;
    }

    function labelFor(isoDate, offset) {
      if (offset === -1) {
        return "Yesterday";
      }

      if (offset === 0) {
        return "Today";
      }

      if (offset === 1) {
        return "Tomorrow";
      }

      return new Intl.DateTimeFormat("en-GB", {
        timeZone: "UTC",
        weekday: "short",
      }).format(new Date(`${isoDate}T00:00:00Z`));
    }

    function shortDate(isoDate) {
      return new Intl.DateTimeFormat("en-GB", {
        day: "2-digit",
        month: "short",
        timeZone: "UTC",
      }).format(new Date(`${isoDate}T00:00:00Z`));
    }

    function cleanDateQuery() {
      const url = new URL(window.location.href);

      if (!url.searchParams.has("date")) {
        return;
      }

      url.searchParams.delete("date");
      window.history.replaceState({}, "", `${url.pathname}${url.search}${url.hash}`);
    }

    function updateRails(activeDate) {
      const today = londonTodayIso();

      document.querySelectorAll("[data-date-rail]").forEach((rail) => {
        rail.querySelectorAll("[data-date-link]").forEach((link) => {
          const offset = Number(link.dataset.dateOffset || 0);
          const isoDate = addDays(today, offset);

          link.dataset.date = isoDate;
          link.classList.toggle("active", isoDate === activeDate);

          if (isoDate === activeDate) {
            link.setAttribute("aria-current", "date");
          } else {
            link.removeAttribute("aria-current");
          }

          const mainLabel = link.querySelector("strong");
          const subLabel = link.querySelector("span");

          if (mainLabel) {
            mainLabel.textContent = labelFor(isoDate, offset);
          }

          if (subLabel) {
            subLabel.textContent = shortDate(isoDate);
          }
        });
      });
    }

    function revealActiveDate() {
      document.querySelectorAll("[data-date-rail]").forEach((rail) => {
        const active = rail.querySelector("[data-date-link].active");

        if (!active) {
          return;
        }

        active.scrollIntoView({
          behavior: "smooth",
          block: "nearest",
          inline: "center",
        });
      });
    }

    function updateSections(activeDate) {
      document.querySelectorAll("[data-date-filter-section]").forEach((section) => {
        const rows = Array.from(section.querySelectorAll("[data-tip-date]"));
        const empty = section.querySelector("[data-date-empty]");
        const count = section.querySelector("[data-date-count]");
        let visible = 0;

        rows.forEach((row) => {
          const matches = row.dataset.tipDate === activeDate;
          row.hidden = !matches;

          if (matches) {
            visible += 1;
          }
        });

        if (empty) {
          empty.hidden = visible > 0;
        }

        if (count) {
          const singular = count.dataset.singular || "tip";
          const plural = count.dataset.plural || "tips";
          count.textContent = `${visible} ${visible === 1 ? singular : plural}`;
        }
      });
    }

    function applyDate(activeDate) {
      updateRails(activeDate);
      updateSections(activeDate);
      window.requestAnimationFrame(revealActiveDate);
    }

    document.addEventListener("click", (event) => {
      const link = event.target.closest("[data-date-link]");

      if (!link) {
        return;
      }

      event.preventDefault();

      const nextDate = link.dataset.date;

      if (!nextDate || !isoPattern.test(nextDate)) {
        return;
      }

      applyDate(nextDate);
    });

    if (document.readyState === "loading") {
      document.addEventListener("DOMContentLoaded", () => {
        cleanDateQuery();
        applyDate(londonTodayIso());
      }, { once: true });
    } else {
      cleanDateQuery();
      applyDate(londonTodayIso());
    }
  })();
</script>

<style>
  .date-rail {
    background: #08224d;
    border: 1px solid #d7dde6;
    border-radius: 8px;
    color: #fff;
    margin-bottom: 1rem;
    min-height: 68px;
    overflow: hidden;
  }

  .date-list {
    display: grid;
    grid-auto-flow: column;
    grid-auto-columns: minmax(94px, 1fr);
    overflow-x: auto;
    scroll-behavior: smooth;
    scroll-snap-type: x proximity;
    scrollbar-width: none;
  }

  .date-list::-webkit-scrollbar {
    display: none;
  }

  .date-item {
    align-items: center;
    appearance: none;
    background: transparent;
    border: 0;
    border-right: 1px solid rgba(255, 255, 255, 0.18);
    color: #c8d7f3;
    cursor: pointer;
    display: flex;
    flex-direction: column;
    font: inherit;
    gap: 0.2rem;
    justify-content: center;
    min-height: 68px;
    min-width: 94px;
    padding: 0.65rem 0.55rem 0.55rem;
    position: relative;
    scroll-snap-align: center;
    text-decoration: none;
    text-transform: uppercase;
  }

  .date-item:hover {
    background: rgba(255, 255, 255, 0.08);
    color: #fff;
  }

  .date-item strong {
    color: inherit;
    font-size: 0.76rem;
    letter-spacing: 0.14em;
    line-height: 1;
  }

  .date-item span {
    color: #8fa6cf;
    font-size: 0.65rem;
    font-weight: 900;
    letter-spacing: 0.12em;
    line-height: 1;
  }

  .date-item.active {
    background: rgba(255, 255, 255, 0.06);
    color: #fff;
  }

  .date-item.active span {
    color: #dbe8ff;
  }

  .date-item.active::after {
    background: var(--ot-brand-orange);
    bottom: 0;
    content: "";
    height: 3px;
    left: 18%;
    position: absolute;
    right: 18%;
  }

  @media (max-width: 720px) {
    .date-rail {
      min-height: 62px;
    }

    .date-list {
      grid-auto-columns: minmax(82px, 1fr);
    }

    .date-item {
      min-height: 62px;
      min-width: 82px;
    }

    .date-item strong {
      font-size: 0.7rem;
      letter-spacing: 0.1em;
    }
  }
</style>
