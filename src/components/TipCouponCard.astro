---
import type { WpPost } from "@/lib/graphql";
import { summarizeTip } from "@/lib/tips";

type Props = {
  post: WpPost;
};

const { post } = Astro.props;
const href = post.uri || `/tips/${post.slug}/`;
const summary = summarizeTip(post);
const activePick = summary.couponPick;
const published = post.date
  ? new Date(post.date).toLocaleDateString("en-GB", {
      day: "2-digit",
      month: "short",
      year: "numeric",
    })
  : null;
---

<article class="coupon-card">
  <div class="time">
    <span class="label">Kickoff</span>
    <strong>{summary.kickoff || "TBC"}</strong>
    {published && <span class="published">Added {published}</span>}
  </div>

  <div class="match">
    <a href={href}>
      <h3>{summary.fixture || "Untitled tip"}</h3>
    </a>
    {(summary.homeTeam || summary.awayTeam) && (
      <p>
        {summary.homeTeam || "Home"} <span>v</span> {summary.awayTeam || "Away"}
      </p>
    )}
  </div>

  <div class="pick">
    <span class="label">1x2 Pick</span>
    <div class="market" aria-label="1x2 coupon pick">
      <span class:list={["market-cell", { active: activePick === "H" }]}>
        <b>1</b>
        <small>Home</small>
      </span>
      <span class:list={["market-cell", { active: activePick === "D" }]}>
        <b>X</b>
        <small>Draw</small>
      </span>
      <span class:list={["market-cell", { active: activePick === "A" }]}>
        <b>2</b>
        <small>Away</small>
      </span>
    </div>
    <strong class="tip-name">{summary.tip || "View tip"}</strong>
  </div>

  <div class="odds">
    <span class="label">Odds</span>
    <strong>{summary.odds || "-"}</strong>
  </div>

  <a class="details" href={href}>Details</a>
</article>

<style>
  .coupon-card {
    align-items: stretch;
    background: #fff;
    border: 1px solid #d8dee8;
    border-radius: 8px;
    display: grid;
    gap: 0;
    grid-template-columns: minmax(150px, 0.75fr) minmax(250px, 1.65fr) minmax(230px, 1.25fr) minmax(84px, 0.45fr) auto;
    min-height: 96px;
    overflow: hidden;
  }

  .time,
  .match,
  .pick,
  .odds {
    border-right: 1px solid #e4e9f1;
    min-width: 0;
    padding: 0.95rem 1rem;
  }

  .label {
    color: #5d697a;
    display: block;
    font-size: 0.75rem;
    font-weight: 800;
    letter-spacing: 0;
    margin-bottom: 0.3rem;
    text-transform: uppercase;
  }

  strong {
    color: #101828;
    display: block;
    font-size: 0.98rem;
    line-height: 1.35;
  }

  .published {
    color: #697586;
    display: block;
    font-size: 0.78rem;
    margin-top: 0.45rem;
  }

  .match a {
    color: inherit;
    text-decoration: none;
  }

  .match h3 {
    font-size: 1rem;
    line-height: 1.32;
    margin: 0;
  }

  .match p {
    color: #516071;
    font-size: 0.9rem;
    margin: 0.45rem 0 0;
  }

  .match span {
    color: #8a94a6;
    font-size: 0.8rem;
    font-weight: 800;
    padding: 0 0.25rem;
    text-transform: uppercase;
  }

  .pick {
    position: relative;
  }

  .market {
    display: grid;
    gap: 0.35rem;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    margin-bottom: 0.55rem;
  }

  .market-cell {
    align-items: center;
    background: #f5f7fb;
    border: 1px solid #d8dee8;
    border-radius: 6px;
    color: #4d5b6c;
    display: flex;
    flex-direction: column;
    gap: 0.05rem;
    min-height: 2.85rem;
    justify-content: center;
    padding: 0.35rem 0.25rem;
    text-align: center;
  }

  .market-cell.active {
    background: #12233d;
    border-color: #12233d;
    color: #fff;
  }

  .market-cell b {
    font-size: 0.95rem;
    line-height: 1;
  }

  .market-cell small {
    font-size: 0.68rem;
    font-weight: 800;
    line-height: 1;
  }

  .tip-name {
    color: #0f766e;
    font-size: 0.9rem;
  }

  .details {
    align-items: center;
    background: #0f766e;
    color: #fff;
    display: inline-flex;
    font-size: 0.9rem;
    font-weight: 800;
    justify-content: center;
    min-width: 86px;
    padding: 1rem;
    text-decoration: none;
  }

  @media (max-width: 860px) {
    .coupon-card {
      grid-template-columns: 1fr 1fr;
    }

    .match {
      grid-column: 1 / -1;
      grid-row: 1;
    }

    .time,
    .pick,
    .odds {
      border-top: 1px solid #e4e9f1;
    }

    .pick {
      border-right: 0;
    }

    .odds {
      border-right: 1px solid #e4e9f1;
    }

    .details {
      min-height: 56px;
      min-width: 0;
    }
  }

  @media (max-width: 560px) {
    .coupon-card {
      grid-template-columns: 1fr;
    }

    .time,
    .match,
    .pick,
    .odds {
      border-right: 0;
    }

    .time,
    .pick,
    .odds,
    .details {
      border-top: 1px solid #e4e9f1;
    }
  }
</style>
