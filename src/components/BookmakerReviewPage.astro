---
export type Bookmaker = {
  slug: string;
  brand: string;
  color: string;
  offerHref?: string;
  rating: number;
  tagline: string;
  established: string;
  license: string;
  minDeposit: string;
  payout: string;
  payments: string[];
  bonus: {
    headline: string;
    code: string;
    cta: string;
    terms: string;
    wagering: string;
    expiry: string;
  };
  pros: string[];
  cons: string[];
  scores: Array<{ label: string; value: number }>;
  sections: Array<{ id: string; title: string; body: string }>;
  faqs: Array<{ q: string; a: string }>;
  verdict?: string;
};

type Props = {
  bookmaker: Bookmaker;
};

const { bookmaker } = Astro.props;
const ratingPct = (bookmaker.rating / 5) * 100;
const offerHref = bookmaker.offerHref ?? "#bonus";
const isExternalOffer = /^https?:\/\//.test(offerHref);
const offerRel = isExternalOffer ? "nofollow sponsored noopener" : "nofollow";
const offerTarget = isExternalOffer ? "_blank" : undefined;
const verdictCopy = bookmaker.verdict ?? `${bookmaker.brand} earns a ${bookmaker.rating.toFixed(1)} on the Oddstips scorecard. It is a strong option for the markets and audience covered above. If the welcome offer suits you, claim it via the button below; otherwise compare alternatives on our free bets page.`;
---

<nav class="breadcrumbs" aria-label="Breadcrumb">
  <a href="/">Home</a>
  <span class="sep">/</span>
  <a href="/reviews/">Bookmaker reviews</a>
  <span class="sep">/</span>
  <span aria-current="page">{bookmaker.brand}</span>
</nav>

<article class="review">
  <section class="hero" style={`--brand-color:${bookmaker.color}`}>
    <div class="hero-main">
      <div class="logo">{bookmaker.brand.slice(0, 2).toUpperCase()}</div>
      <div class="hero-text">
        <p class="eyebrow">Bookmaker review</p>
        <h1>{bookmaker.brand} review</h1>
        <p class="tagline">{bookmaker.tagline}</p>
        <div class="hero-meta">
          <span>Established {bookmaker.established}</span>
          <span aria-hidden="true">|</span>
          <span>Licence: {bookmaker.license}</span>
        </div>
      </div>
    </div>

    <aside class="hero-rating">
      <div class="rating-circle" style={`--pct:${ratingPct}%`}>
        <span><strong>{bookmaker.rating.toFixed(1)}</strong><small>/ 5</small></span>
      </div>
      <div class="hero-cta-block">
        <span class="bonus-tag">Welcome offer</span>
        <p class="bonus-headline">{bookmaker.bonus.headline}</p>
        <a class="cta" href={offerHref} rel={offerRel} target={offerTarget}>{bookmaker.bonus.cta}</a>
        <p class="bonus-terms">{bookmaker.bonus.terms}</p>
      </div>
    </aside>
  </section>

  <nav class="section-nav" aria-label="On this page">
    <a href="#bonus">Welcome bonus</a>
    {bookmaker.sections.map((sec) => <a href={`#${sec.id}`}>{sec.title}</a>)}
    <a href="#pros-cons">Pros &amp; cons</a>
    <a href="#verdict">Verdict</a>
    <a href="#faqs">FAQs</a>
  </nav>

  <section class="quick-facts" aria-label="Quick facts">
    <div><span class="label">Min deposit</span><strong>{bookmaker.minDeposit}</strong></div>
    <div><span class="label">Payout speed</span><strong>{bookmaker.payout}</strong></div>
    <div><span class="label">Wagering</span><strong>{bookmaker.bonus.wagering}</strong></div>
    <div><span class="label">Bonus expiry</span><strong>{bookmaker.bonus.expiry}</strong></div>
    <div><span class="label">Code</span><strong>{bookmaker.bonus.code}</strong></div>
  </section>

  <section class="scores" aria-label="Category scores">
    {bookmaker.scores.map((score) => (
      <div class="score-row">
        <span class="score-label">{score.label}</span>
        <div class="score-bar"><span style={`--w:${(score.value / 5) * 100}%`}></span></div>
        <strong>{score.value.toFixed(1)}</strong>
      </div>
    ))}
  </section>

  <section class="bonus-module" id="bonus" aria-labelledby="bonus-heading">
    <div class="bonus-text">
      <p class="eyebrow">Welcome offer</p>
      <h2 id="bonus-heading">{bookmaker.bonus.headline}</h2>
      <ul class="bonus-points">
        <li><span class="check">v</span> Wagering: {bookmaker.bonus.wagering}</li>
        <li><span class="check">v</span> Min deposit: {bookmaker.minDeposit}</li>
        <li><span class="check">v</span> Expiry: {bookmaker.bonus.expiry}</li>
        <li><span class="check">v</span> Code: <strong>{bookmaker.bonus.code}</strong></li>
      </ul>
      <p class="bonus-terms">{bookmaker.bonus.terms}</p>
    </div>
    <div class="bonus-cta-card">
      <span class="logo logo-lg">{bookmaker.brand.slice(0, 2).toUpperCase()}</span>
      <strong>{bookmaker.brand}</strong>
      <a class="cta cta-block" href={offerHref} rel={offerRel} target={offerTarget}>{bookmaker.bonus.cta}</a>
      <p>18+. T&amp;Cs apply.</p>
    </div>
  </section>

  <div class="review-layout">
    <div class="review-body">
      {bookmaker.sections.map((sec) => (
        <section class="review-section" id={sec.id}>
          <h2>{sec.title}</h2>
          <div class="content" set:html={sec.body} />
        </section>
      ))}

      <section class="pros-cons" id="pros-cons" aria-labelledby="prosheading">
        <h2 id="prosheading">Pros and cons</h2>
        <div class="pc-grid">
          <div class="pc-card pros-card">
            <h3>Pros</h3>
            <ul>
              {bookmaker.pros.map((p) => (
                <li><span class="check">v</span> {p}</li>
              ))}
            </ul>
          </div>
          <div class="pc-card cons-card">
            <h3>Cons</h3>
            <ul>
              {bookmaker.cons.map((c) => (
                <li><span class="cross">x</span> {c}</li>
              ))}
            </ul>
          </div>
        </div>
      </section>

      <section class="verdict" id="verdict" aria-labelledby="verdict-heading">
        <div class="verdict-score">
          <strong>{bookmaker.rating.toFixed(1)}</strong>
          <span>/ 5</span>
        </div>
        <div>
          <h2 id="verdict-heading">Oddstips verdict</h2>
          <p set:html={verdictCopy} />
          <a class="cta" href={offerHref} rel={offerRel} target={offerTarget}>{bookmaker.bonus.cta}</a>
        </div>
      </section>

      <section class="faqs" id="faqs" aria-labelledby="faq-heading">
        <h2 id="faq-heading">{bookmaker.brand} FAQs</h2>
        <div class="faq-list">
          {bookmaker.faqs.map((faq) => (
            <details>
              <summary>{faq.q}</summary>
              <p>{faq.a}</p>
            </details>
          ))}
        </div>
      </section>

      <p class="responsible">18+ only. Gamble responsibly. BeGambleAware.org. GamCare.org.uk.</p>
    </div>

    <aside class="review-sidebar" aria-label="Review sidebar">
      <div class="sidebar-card sticky-card">
        <span class="logo logo-md">{bookmaker.brand.slice(0, 2).toUpperCase()}</span>
        <strong>{bookmaker.brand}</strong>
        <div class="sidebar-rating">
          <div class="stars"><span class="stars-fill" style={`--w:${ratingPct}%`}></span></div>
          <small>{bookmaker.rating.toFixed(1)} / 5</small>
        </div>
        <p class="sidebar-headline">{bookmaker.bonus.headline}</p>
        <a class="cta cta-block" href={offerHref} rel={offerRel} target={offerTarget}>{bookmaker.bonus.cta}</a>
        <p class="card-terms">18+. T&amp;Cs apply.</p>
      </div>

      <div class="sidebar-card">
        <h3>Payments accepted</h3>
        <ul class="payments">
          {bookmaker.payments.map((p) => (
            <li>{p}</li>
          ))}
        </ul>
      </div>
    </aside>
  </div>
</article>

<a class="sticky-cta" href={offerHref} rel={offerRel} target={offerTarget}>
  <strong>{bookmaker.brand}</strong>
  <span>Claim Welcome Offer</span>
</a>

<style>
  .breadcrumbs { color: var(--ot-muted); font-size: 0.85rem; margin-bottom: 1rem; }
  .breadcrumbs a { color: var(--ot-ink-2); text-decoration: none; }
  .breadcrumbs .sep { color: var(--ot-muted-2); margin: 0 0.35rem; }

  .review { display: grid; gap: 1.25rem; padding-bottom: 5rem; }

  /* HERO */
  .hero {
    background: linear-gradient(135deg, var(--ot-ink) 0%, color-mix(in srgb, var(--brand-color, var(--ot-ink-2)) 55%, var(--ot-ink) 45%) 100%);
    border-radius: var(--ot-radius);
    color: #fff;
    display: grid;
    gap: 0;
    grid-template-columns: 1.4fr 1fr;
    overflow: hidden;
  }
  .hero-main { display: flex; gap: 1.25rem; padding: 2rem 2rem 1.75rem; }
  .logo {
    align-items: center;
    background: var(--brand-color, var(--ot-ink-2));
    border-radius: 12px;
    color: #fff;
    display: inline-flex;
    flex: 0 0 auto;
    font-size: 1.4rem;
    font-weight: 900;
    height: 72px;
    justify-content: center;
    width: 100px;
  }
  .hero h1 { color: #fff; margin: 0; }
  .hero .eyebrow { color: var(--ot-gold); }
  .tagline { color: #d5e0f4; font-size: 1.02rem; margin: 0.5rem 0 0.85rem; }
  .hero-meta { color: #aab8d3; display: flex; flex-wrap: wrap; font-size: 0.85rem; gap: 0.6rem; }

  .hero-rating {
    background: rgba(255,255,255,0.06);
    border-left: 1px solid rgba(255,255,255,0.14);
    display: grid;
    grid-template-columns: auto 1fr;
    gap: 1.25rem;
    padding: 1.75rem 1.75rem;
  }
  .rating-circle {
    align-items: center;
    background:
      conic-gradient(var(--ot-gold) calc(var(--pct, 0%)), rgba(255,255,255,0.18) 0);
    border-radius: 999px;
    display: flex;
    height: 88px;
    justify-content: center;
    width: 88px;
    position: relative;
  }
  .rating-circle::before {
    background: #0f2a5a;
    border-radius: 999px;
    content: "";
    inset: 6px;
    position: absolute;
  }
  .rating-circle span { position: relative; text-align: center; }
  .rating-circle strong { color: #fff; display: block; font-size: 1.5rem; line-height: 1; }
  .rating-circle small { color: var(--ot-gold); font-size: 0.75rem; font-weight: 900; }

  .hero-cta-block { display: flex; flex-direction: column; gap: 0.45rem; }
  .bonus-tag {
    align-self: flex-start;
    background: var(--ot-gold);
    border-radius: 999px;
    color: var(--ot-ink);
    font-size: 0.7rem;
    font-weight: 900;
    letter-spacing: 0.08em;
    padding: 0.25rem 0.6rem;
    text-transform: uppercase;
  }
  .bonus-headline { color: #fff; font-size: 1.05rem; font-weight: 900; margin: 0.2rem 0; }
  .cta {
    align-items: center;
    background: var(--ot-green);
    border-radius: 999px;
    color: #fff;
    display: inline-flex;
    font-size: 0.95rem;
    font-weight: 900;
    justify-content: center;
    padding: 0.75rem 1.2rem;
    text-decoration: none;
  }
  .cta:hover { background: var(--ot-green-2); }
  .cta-block { width: 100%; }
  .bonus-terms { color: #aab8d3; font-size: 0.72rem; margin: 0.5rem 0 0; }

  @media (max-width: 880px) {
    .hero { grid-template-columns: 1fr; }
    .hero-rating { border-left: 0; border-top: 1px solid rgba(255,255,255,0.14); }
    .hero-main { flex-direction: column; padding: 1.5rem; }
  }

  /* SECTION NAV */
  .section-nav {
    background: var(--ot-surface);
    border: 1px solid var(--ot-border);
    border-radius: var(--ot-radius);
    display: flex;
    flex-wrap: nowrap;
    gap: 0.25rem;
    overflow-x: auto;
    padding: 0.35rem;
    position: sticky;
    top: 4rem;
    z-index: 5;
  }
  .section-nav::-webkit-scrollbar { display: none; }
  .section-nav a {
    border-radius: 999px;
    color: var(--ot-ink);
    font-size: 0.85rem;
    font-weight: 800;
    padding: 0.5rem 0.85rem;
    text-decoration: none;
    white-space: nowrap;
  }
  .section-nav a:hover { background: var(--ot-surface-2); }

  /* QUICK FACTS */
  .quick-facts {
    background: var(--ot-surface);
    border: 1px solid var(--ot-border);
    border-radius: var(--ot-radius);
    display: grid;
    grid-template-columns: repeat(5, 1fr);
    overflow: hidden;
  }
  .quick-facts > div { border-right: 1px solid var(--ot-border); padding: 1rem; }
  .quick-facts > div:last-child { border-right: 0; }
  .label {
    color: var(--ot-muted);
    display: block;
    font-size: 0.7rem;
    font-weight: 800;
    letter-spacing: 0.08em;
    margin-bottom: 0.3rem;
    text-transform: uppercase;
  }
  .quick-facts strong { color: var(--ot-text); }
  @media (max-width: 720px) {
    .quick-facts { grid-template-columns: 1fr 1fr; }
    .quick-facts > div { border-bottom: 1px solid var(--ot-border); }
    .quick-facts > div:nth-child(2n) { border-right: 0; }
  }

  /* SCORES */
  .scores {
    background: var(--ot-surface);
    border: 1px solid var(--ot-border);
    border-radius: var(--ot-radius);
    display: grid;
    gap: 0.65rem;
    padding: 1.25rem;
  }
  .score-row {
    align-items: center;
    display: grid;
    gap: 0.85rem;
    grid-template-columns: 180px 1fr 40px;
  }
  .score-label { color: var(--ot-text); font-weight: 800; }
  .score-bar { background: #ebeef4; border-radius: 999px; height: 8px; overflow: hidden; }
  .score-bar span { background: var(--ot-green); display: block; height: 100%; width: var(--w, 0%); }
  .scores strong { color: var(--ot-ink); text-align: right; }
  @media (max-width: 540px) { .score-row { grid-template-columns: 120px 1fr 32px; } }

  /* BONUS MODULE */
  .bonus-module {
    background: var(--ot-surface);
    border: 1px solid var(--ot-border);
    border-radius: var(--ot-radius);
    display: grid;
    gap: 0;
    grid-template-columns: 1.4fr 1fr;
    overflow: hidden;
  }
  .bonus-text { padding: 1.5rem; }
  .bonus-points {
    color: var(--ot-text-2);
    display: grid;
    gap: 0.4rem;
    list-style: none;
    margin: 1rem 0;
    padding: 0;
  }
  .check {
    background: var(--ot-green);
    border-radius: 999px;
    color: #fff;
    display: inline-block;
    font-size: 0.7rem;
    font-weight: 900;
    height: 18px;
    line-height: 18px;
    margin-right: 0.4rem;
    text-align: center;
    width: 18px;
  }
  .bonus-cta-card {
    align-items: center;
    background: linear-gradient(180deg, var(--ot-ink) 0%, var(--ot-ink-2) 100%);
    color: #fff;
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
    justify-content: center;
    padding: 1.5rem;
    text-align: center;
  }
  .logo-lg { background: var(--brand-color, var(--ot-ink-2)); height: 60px; width: 120px; }
  .logo-md { background: var(--brand-color, var(--ot-ink-2)); color: #fff; height: 40px; width: 64px; }
  .bonus-cta-card strong { color: #fff; font-size: 1.1rem; }
  .bonus-cta-card p { color: #aab8d3; font-size: 0.75rem; margin: 0; }
  @media (max-width: 720px) { .bonus-module { grid-template-columns: 1fr; } }

  /* LAYOUT */
  .review-layout {
    align-items: start;
    display: grid;
    gap: 1.25rem;
    grid-template-columns: minmax(0, 1fr) 320px;
  }
  .review-body { display: grid; gap: 1.5rem; }
  .review-section {
    background: var(--ot-surface);
    border: 1px solid var(--ot-border);
    border-radius: var(--ot-radius);
    padding: 1.5rem;
    scroll-margin-top: 6rem;
  }
  .review-section h2 { margin-top: 0; }
  .content :global(p) { color: var(--ot-text-2); }
  .content :global(a) { color: var(--ot-green); font-weight: 800; }

  /* PROS / CONS */
  .pros-cons {
    background: var(--ot-surface);
    border: 1px solid var(--ot-border);
    border-radius: var(--ot-radius);
    padding: 1.5rem;
    scroll-margin-top: 6rem;
  }
  .pros-cons h2 { margin-top: 0; }
  .pc-grid { display: grid; gap: 1rem; grid-template-columns: 1fr 1fr; }
  .pc-card { background: var(--ot-surface-2); border-radius: var(--ot-radius-sm); padding: 1.1rem; }
  .pros-card { border-left: 4px solid var(--ot-green); }
  .cons-card { border-left: 4px solid var(--ot-danger); }
  .pc-card h3 { font-size: 1rem; margin: 0 0 0.65rem; }
  .pc-card ul { display: grid; gap: 0.45rem; list-style: none; margin: 0; padding: 0; }
  .pc-card li { color: var(--ot-text-2); }
  .cross {
    background: var(--ot-danger);
    border-radius: 999px;
    color: #fff;
    display: inline-block;
    font-size: 0.7rem;
    font-weight: 900;
    height: 18px;
    line-height: 18px;
    margin-right: 0.4rem;
    text-align: center;
    width: 18px;
  }
  @media (max-width: 720px) { .pc-grid { grid-template-columns: 1fr; } }

  /* VERDICT */
  .verdict {
    background: linear-gradient(135deg, var(--ot-ink) 0%, var(--ot-ink-2) 100%);
    border-radius: var(--ot-radius);
    color: #fff;
    display: grid;
    gap: 1.25rem;
    grid-template-columns: auto 1fr;
    padding: 1.75rem;
    scroll-margin-top: 6rem;
  }
  .verdict h2 { color: #fff; margin: 0 0 0.5rem; }
  .verdict p { color: #d5e0f4; margin: 0 0 1rem; }
  .verdict p a { color: var(--ot-gold); }
  .verdict-score {
    align-items: center;
    background: var(--ot-gold);
    border-radius: 12px;
    color: var(--ot-ink);
    display: flex;
    flex-direction: column;
    height: 100px;
    justify-content: center;
    width: 100px;
  }
  .verdict-score strong { font-size: 2rem; line-height: 1; }
  .verdict-score span { font-size: 0.85rem; font-weight: 800; }

  /* FAQS */
  .faqs { background: var(--ot-surface); border: 1px solid var(--ot-border); border-radius: var(--ot-radius); padding: 1.5rem; scroll-margin-top: 6rem; }
  .faqs h2 { margin-top: 0; }
  .faq-list { display: grid; gap: 0.5rem; }
  details {
    background: var(--ot-surface-2);
    border: 1px solid var(--ot-border);
    border-radius: var(--ot-radius-sm);
    padding: 0.85rem 1rem;
  }
  summary { cursor: pointer; font-weight: 800; list-style: none; }
  summary::after { color: var(--ot-muted); content: "+"; float: right; font-weight: 900; }
  details[open] summary::after { content: "-"; }
  details p { color: var(--ot-text-2); margin: 0.6rem 0 0; }

  .responsible {
    background: #fff7ed;
    border: 1px solid #fbd9a8;
    border-radius: var(--ot-radius-sm);
    color: #7a4a0c;
    padding: 0.85rem 1rem;
  }

  /* SIDEBAR */
  .review-sidebar { display: grid; gap: 1rem; }
  .sidebar-card {
    background: var(--ot-surface);
    border: 1px solid var(--ot-border);
    border-radius: var(--ot-radius);
    padding: 1.25rem;
  }
  .sticky-card { position: sticky; top: 6rem; text-align: center; }
  .sticky-card strong { display: block; font-size: 1.05rem; margin: 0.5rem 0 0.25rem; }
  .sidebar-rating { align-items: center; display: flex; gap: 0.4rem; justify-content: center; margin: 0.35rem 0 0.6rem; }
  .stars { background: #ebeef4; border-radius: 999px; height: 6px; overflow: hidden; width: 90px; }
  .stars-fill { background: var(--ot-gold); display: block; height: 100%; width: var(--w, 0%); }
  .sidebar-headline { color: var(--ot-text); font-weight: 800; margin: 0 0 1rem; }
  .card-terms { color: var(--ot-muted); font-size: 0.72rem; margin: 0.6rem 0 0; }
  .payments { display: grid; gap: 0.4rem; list-style: none; margin: 0; padding: 0; }
  .payments li {
    background: var(--ot-surface-2);
    border-radius: var(--ot-radius-sm);
    color: var(--ot-text);
    font-size: 0.88rem;
    font-weight: 700;
    padding: 0.55rem 0.75rem;
  }

  @media (max-width: 880px) {
    .review-layout { grid-template-columns: 1fr; }
    .sticky-card { position: static; }
    .section-nav { top: 0; }
  }

  /* STICKY MOBILE CTA */
  .sticky-cta {
    align-items: center;
    background: var(--ot-ink);
    border-top: 3px solid var(--ot-gold);
    bottom: 0;
    color: #fff;
    display: none;
    gap: 1rem;
    justify-content: space-between;
    left: 0;
    padding: 0.65rem 0.85rem;
    position: fixed;
    right: 0;
    text-decoration: none;
    z-index: 40;
  }
  .sticky-cta strong { color: #fff; font-size: 0.95rem; }
  .sticky-cta span {
    background: var(--ot-green);
    border-radius: 999px;
    color: #fff;
    font-size: 0.85rem;
    font-weight: 900;
    margin-left: auto;
    padding: 0.6rem 1rem;
  }
  .sticky-cta:hover span { background: var(--ot-green-2); }
  @media (max-width: 880px) { .sticky-cta { display: flex; } }
</style>
