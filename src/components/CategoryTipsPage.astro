---
import CouponRow from "@/components/CouponRow.astro";
import CategorySidebar from "@/components/CategorySidebar.astro";
import DateRail from "@/components/DateRail.astro";
import HubHero from "@/components/HubHero.astro";
import type { WpCategory, WpPost } from "@/lib/graphql";
import { placeholderRelatedTips } from "@/lib/relatedTips";
import { getCategorySeoCopy } from "@/lib/categorySeoCopy";

type CategoryWithPosts = WpCategory & {
  posts?: {
    nodes: WpPost[];
  };
  categoryTopSeoText?: {
    categoryTopSeoTextEditor?: string;
  };
  categoryBottomSeoText?: {
    categoryBottomSeoText?: string;
  };
};

type Props = {
  category: CategoryWithPosts;
};

const { category } = Astro.props;
const hasWpGraphQL = Boolean(import.meta.env.WPGRAPHQL_ENDPOINT);
const livePosts = category.posts?.nodes ?? [];
// Local-preview fallback when WPGraphQL is not configured.
const posts = livePosts.length ? livePosts : hasWpGraphQL ? [] : placeholderRelatedTips;

const fallbackSeo = getCategorySeoCopy(category.slug);
const topSeo = category.categoryTopSeoText?.categoryTopSeoTextEditor || fallbackSeo.top || "";
const bottomSeo = category.categoryBottomSeoText?.categoryBottomSeoText || fallbackSeo.bottom || "";

function titleCaseSegment(segment: string) {
  return segment
    .replace(/-/g, " ")
    .replace(/\b\w/g, (letter) => letter.toUpperCase());
}

function sportNameFromUri(uri?: string) {
  const sportSlug = uri?.replace(/^\/+|\/+$/g, "").split("/").filter(Boolean)[0];

  return sportSlug ? titleCaseSegment(sportSlug) : "Sports";
}

const breadcrumb = (() => {
  const segments = (category.uri || "")
    .replace(/^\/+|\/+$/g, "")
    .split("/")
    .filter(Boolean);
  const crumbs: Array<{ label: string; href?: string }> = [{ label: "Home", href: "/" }];
  let path = "";
  segments.forEach((segment, i) => {
    path += `/${segment}`;
    const label = segment
      .replace(/-/g, " ")
      .replace(/\b\w/g, (c) => c.toUpperCase());
    crumbs.push({ label, href: i === segments.length - 1 ? undefined : `${path}/` });
  });
  if (crumbs.length === 1) {
    crumbs.push({ label: category.name || "Category" });
  }
  return crumbs;
})();

const sportName = sportNameFromUri(category.uri);
const isFootballCategory = sportName.toLowerCase() === "football";
const heading = category.name
  ? `${category.name} ${sportName} Betting Tips & Predictions`
  : "Betting Tips & Predictions";

// Wrap category.description in a <p> so HubHero's :global(p) styles still apply
// if WP returns plain text rather than markup.
const descriptionLede = category.description
  ? (/^\s*<\w+/.test(category.description) ? category.description : `<p>${category.description}</p>`)
  : "";
const heroLede = topSeo || descriptionLede || "";
---

<nav class="breadcrumbs" aria-label="Breadcrumb">
  {breadcrumb.map((crumb, i) => (
    <>
      {crumb.href ? <a href={crumb.href}>{crumb.label}</a> : <span aria-current="page">{crumb.label}</span>}
      {i < breadcrumb.length - 1 && <span class="sep">/</span>}
    </>
  ))}
</nav>

<HubHero
  eyebrow={`${sportName} betting`}
  heading={heading}
  ledeHtml={heroLede}
/>

<div class="cat-layout">
  <main class="cat-main">
    <DateRail />

    <section class="post-list" aria-labelledby="latest-heading" data-date-filter-section>
      <header class="post-list-head">
        <p class="eyebrow">Latest predictions</p>
        <h2 id="latest-heading">{category.name || "Latest"} tips</h2>
        <p class="post-list-meta">
          <span data-date-count data-singular="tip" data-plural="tips">
            {posts.length} {posts.length === 1 ? "tip" : "tips"}
          </span>
        </p>
      </header>
      {posts.length > 0 ? (
        <div class="post-list-rows" data-date-filter-list>
          {posts.map((post) => <CouponRow post={post} />)}
        </div>
      ) : null}
      <p class="empty-state" data-date-empty hidden={posts.length > 0}>No tips found for this date. Try another date.</p>
    </section>

    {bottomSeo && (
      <section class="cat-bottom-seo" aria-label="Category guide">
        <div class="seo-prose" set:html={bottomSeo} />
      </section>
    )}
  </main>

  <CategorySidebar
    currentPath={category.uri}
    showInternational={isFootballCategory}
    showPopularLeagues={isFootballCategory}
  />
</div>

<style>
  .breadcrumbs {
    color: var(--ot-muted);
    font-size: 0.85rem;
    margin-bottom: 1rem;
  }
  .breadcrumbs a { color: var(--ot-brand-blue); text-decoration: none; }
  .breadcrumbs a:hover { text-decoration: underline; }
  .breadcrumbs .sep { color: var(--ot-muted-2); margin: 0 0.35rem; }

  .cat-layout {
    display: grid;
    gap: 1.5rem;
    grid-template-columns: minmax(0, 1fr) 300px;
  }

  .cat-main {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
    min-width: 0;
  }

  .cat-bottom-seo {
    background: var(--ot-surface);
    border: 1px solid var(--ot-border);
    border-radius: var(--ot-radius);
    box-shadow: var(--ot-shadow-sm);
    padding: 1.75rem 1.75rem 2rem;
  }
  .seo-prose {
    color: var(--ot-text);
    font-size: 1rem;
    line-height: 1.7;
    max-width: 70ch;
  }
  .seo-prose :global(h2) {
    border-bottom: 2px solid var(--ot-brand-blue-soft);
    color: var(--ot-brand-blue-dark);
    font-size: 1.25rem;
    margin: 2rem 0 0.85rem;
    padding-bottom: 0.4rem;
  }
  .seo-prose :global(h2:first-child) { margin-top: 0; }
  .seo-prose :global(h3) {
    color: var(--ot-brand-blue-dark);
    font-size: 1.1rem;
    margin: 1.5rem 0 0.6rem;
  }
  .seo-prose :global(p) {
    color: var(--ot-text-2);
    margin: 0 0 1rem;
  }
  .seo-prose :global(strong) { color: var(--ot-text); }
  .seo-prose :global(a) {
    color: var(--ot-brand-blue);
    font-weight: 700;
    text-decoration: underline;
    text-decoration-color: var(--ot-brand-blue-soft);
    text-underline-offset: 3px;
  }
  .seo-prose :global(a:hover) {
    color: var(--ot-brand-blue-dark);
    text-decoration-color: var(--ot-brand-blue);
  }
  .seo-prose :global(ul), .seo-prose :global(ol) { margin: 0 0 1.25rem; padding-left: 1.4rem; }

  .post-list {
    background: var(--ot-surface);
    border: 1px solid var(--ot-border);
    border-radius: var(--ot-radius);
    box-shadow: var(--ot-shadow-sm);
    overflow: hidden;
  }
  .post-list-head {
    align-items: end;
    background: linear-gradient(180deg, #f3f8fd 0%, #ffffff 100%);
    border-bottom: 1px solid var(--ot-border);
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem 1rem;
    justify-content: space-between;
    padding: 1.1rem 1.25rem;
  }
  .post-list-head .eyebrow {
    color: var(--ot-brand-blue);
    font-size: 0.7rem;
    font-weight: 900;
    letter-spacing: 0.1em;
    margin: 0;
    text-transform: uppercase;
    width: 100%;
  }
  .post-list-head h2 {
    color: var(--ot-text);
    font-size: 1.2rem;
    margin: 0.2rem 0 0;
  }
  .post-list-meta {
    color: var(--ot-muted);
    font-size: 0.8rem;
    margin: 0;
  }

  .post-list-rows {
    display: grid;
  }

  .empty-state {
    color: var(--ot-muted);
    font-size: 0.95rem;
    margin: 0;
    padding: 1.5rem 1.25rem;
  }

  @media (max-width: 880px) {
    .cat-layout { grid-template-columns: 1fr; }
  }
</style>
