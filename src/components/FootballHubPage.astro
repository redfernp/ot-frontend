---
import CouponRow from "@/components/CouponRow.astro";
import CategorySidebar from "@/components/CategorySidebar.astro";
import DateRail from "@/components/DateRail.astro";
import HubHero from "@/components/HubHero.astro";
import { getInternationalTips, type WpCategory, type WpPost } from "@/lib/graphql";
import { placeholderInternationalTips, placeholderRelatedTips } from "@/lib/relatedTips";
import { getCategorySeoCopy } from "@/lib/categorySeoCopy";

// Reads ACF Pro fields category_top_seo_text + category_bottom_seo_text from WP.
// Falls back to src/lib/categorySeoCopy for dev preview / unpopulated categories.
type CategoryWithSeo = WpCategory & {
  posts?: { nodes: WpPost[] };
  categoryTopSeoText?: {
    categoryTopSeoTextEditor?: string;
  };
  categoryBottomSeoText?: {
    categoryBottomSeoText?: string;
  };
};

type Props = {
  category: CategoryWithSeo;
};

const { category } = Astro.props;
const hasWpGraphQL = Boolean(import.meta.env.WPGRAPHQL_ENDPOINT);
const livePosts = category.posts?.nodes ?? [];
const posts = livePosts.length ? livePosts : hasWpGraphQL ? [] : placeholderRelatedTips;

const fallbackSeo = getCategorySeoCopy(category.slug);
const topSeo = category.categoryTopSeoText?.categoryTopSeoTextEditor || fallbackSeo.top || "";
const bottomSeo = category.categoryBottomSeoText?.categoryBottomSeoText || fallbackSeo.bottom || "";

const categoryName = category.name || "Football";

// Dynamic: today's top international matches.
// Local placeholders are used only when WPGraphQL is not configured.
const liveInternational = await getInternationalTips(6).catch(() => []);
const internationalPosts = liveInternational.length || !hasWpGraphQL
  ? (liveInternational.length ? liveInternational : placeholderInternationalTips)
  : [];

const heroLede =
  topSeo ||
  category.description ||
  "<p>Looking for today's best Football 1x2 betting tips and predictions? Oddstips covers every major league, cup and international fixture with Bet365 odds, value angles and accumulator picks. Browse the latest predictions below.</p>";
---

<nav class="breadcrumbs" aria-label="Breadcrumb">
  <a href="/">Home</a>
  <span class="sep">/</span>
  <span aria-current="page">{categoryName}</span>
</nav>

<HubHero
  eyebrow="Football 1x2 betting"
  heading={`${categoryName} 1x2 Betting Tips & Predictions`}
  ledeHtml={heroLede}
/>

<div class="hub-layout">
  <main class="hub-main">
    <DateRail />

    <section class="post-list internationals" aria-labelledby="internationals-heading" data-date-filter-section>
      <header class="post-list-head">
        <p class="eyebrow on-orange">International</p>
        <h2 id="internationals-heading">Top International Matches</h2>
        <p class="post-list-meta">
          <span data-date-count data-singular="match" data-plural="matches">
            {internationalPosts.length} {internationalPosts.length === 1 ? "match" : "matches"}
          </span>
        </p>
      </header>
      {internationalPosts.length > 0 ? (
        <div class="post-list-rows" data-date-filter-list>
          {internationalPosts.map((post) => <CouponRow post={post} />)}
        </div>
      ) : null}
      <p class="empty-state" data-date-empty hidden={internationalPosts.length > 0}>No international matches found for this date. Try another date.</p>
    </section>

    <section class="post-list" aria-labelledby="latest-football-heading" data-date-filter-section>
      <header class="post-list-head">
        <p class="eyebrow">All predictions</p>
        <h2 id="latest-football-heading">All The Latest Football Betting Predictions</h2>
        <p class="post-list-meta">
          <span data-date-count data-singular="tip" data-plural="tips">
            {posts.length} {posts.length === 1 ? "tip" : "tips"}
          </span>
        </p>
      </header>
      {posts.length > 0 ? (
        <div class="post-list-rows" data-date-filter-list>
          {posts.map((post) => <CouponRow post={post} />)}
        </div>
      ) : null}
      <p class="empty-state" data-date-empty hidden={posts.length > 0}>No football tips found for this date. Try another date.</p>
    </section>

    {bottomSeo && (
      <section class="seo-content" aria-label="Category guide">
        <div class="seo-prose" set:html={bottomSeo} />
      </section>
    )}
  </main>

  <CategorySidebar currentPath={category.uri} />
</div>

<style>
  .breadcrumbs {
    color: var(--ot-muted);
    font-size: 0.85rem;
    margin-bottom: 1rem;
  }
  .breadcrumbs a { color: var(--ot-brand-blue); text-decoration: none; }
  .breadcrumbs a:hover { text-decoration: underline; }
  .breadcrumbs .sep { color: var(--ot-muted-2); margin: 0 0.35rem; }

  .hub-layout {
    display: grid;
    gap: 1.5rem;
    grid-template-columns: minmax(0, 1fr) 300px;
  }

  .hub-main {
    display: flex;
    flex-direction: column;
    gap: 1.75rem;
    min-width: 0;
  }

  /* POST LIST */
  .post-list {
    background: var(--ot-surface);
    border: 1px solid var(--ot-border);
    border-radius: var(--ot-radius);
    box-shadow: var(--ot-shadow-sm);
    overflow: hidden;
  }
  .post-list-head {
    align-items: end;
    background: linear-gradient(180deg, #f3f8fd 0%, #ffffff 100%);
    border-bottom: 1px solid var(--ot-border);
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem 1rem;
    justify-content: space-between;
    padding: 1.1rem 1.25rem;
  }
  .post-list-head .eyebrow {
    color: var(--ot-brand-blue);
    font-size: 0.7rem;
    font-weight: 900;
    letter-spacing: 0.1em;
    margin: 0;
    text-transform: uppercase;
    width: 100%;
  }
  .post-list-head .eyebrow.on-orange { color: var(--ot-brand-orange); }
  .post-list-head h2 {
    color: var(--ot-text);
    font-size: 1.15rem;
    margin: 0.2rem 0 0;
  }
  .post-list-meta {
    color: var(--ot-muted);
    font-size: 0.8rem;
    margin: 0;
  }

  .internationals {
    border-top: 4px solid var(--ot-brand-orange);
  }
  .empty-state {
    color: var(--ot-muted);
    font-size: 0.95rem;
    margin: 0;
    padding: 1.5rem 1.25rem;
  }

  /* SEO CONTENT */
  .seo-content {
    background: var(--ot-surface);
    border: 1px solid var(--ot-border);
    border-radius: var(--ot-radius);
    box-shadow: var(--ot-shadow-sm);
    padding: 1.75rem 1.75rem 2rem;
  }
  .seo-prose {
    color: var(--ot-text);
    font-size: 1rem;
    line-height: 1.7;
    max-width: 70ch;
  }
  .seo-prose :global(h2) {
    border-bottom: 2px solid var(--ot-brand-blue-soft);
    color: var(--ot-brand-blue-dark);
    font-size: 1.25rem;
    margin: 2rem 0 0.85rem;
    padding-bottom: 0.4rem;
  }
  .seo-prose :global(h2:first-child) { margin-top: 0; }
  .seo-prose :global(h3) {
    color: var(--ot-brand-blue-dark);
    font-size: 1.1rem;
    margin: 1.5rem 0 0.6rem;
  }
  .seo-prose :global(p) {
    color: var(--ot-text-2);
    margin: 0 0 1rem;
  }
  .seo-prose :global(strong) { color: var(--ot-text); }
  .seo-prose :global(a) {
    color: var(--ot-brand-blue);
    font-weight: 700;
    text-decoration: underline;
    text-decoration-color: var(--ot-brand-blue-soft);
    text-underline-offset: 3px;
  }
  .seo-prose :global(a:hover) {
    color: var(--ot-brand-blue-dark);
    text-decoration-color: var(--ot-brand-blue);
  }
  .seo-prose :global(ul),
  .seo-prose :global(ol) {
    margin: 0 0 1.25rem;
    padding-left: 1.4rem;
  }
  .seo-prose :global(ul) { list-style: none; padding-left: 0; }
  .seo-prose :global(ul li) {
    color: var(--ot-text-2);
    padding: 0.2rem 0 0.2rem 1.6rem;
    position: relative;
  }
  .seo-prose :global(ul li)::before {
    background: var(--ot-brand-orange);
    border-radius: 999px;
    content: "";
    height: 7px;
    left: 0.3rem;
    position: absolute;
    top: 0.85rem;
    width: 7px;
  }
  .seo-prose :global(ol) {
    counter-reset: seo-counter;
    list-style: none;
    padding-left: 0;
  }
  .seo-prose :global(ol li) {
    color: var(--ot-text-2);
    counter-increment: seo-counter;
    padding: 0.4rem 0 0.4rem 2.2rem;
    position: relative;
  }
  .seo-prose :global(ol li)::before {
    background: var(--ot-brand-blue);
    border-radius: 6px;
    color: #fff;
    content: counter(seo-counter);
    font-size: 0.78rem;
    font-weight: 900;
    height: 22px;
    left: 0;
    line-height: 22px;
    position: absolute;
    text-align: center;
    top: 0.45rem;
    width: 22px;
  }

  @media (max-width: 880px) {
    .hub-layout { grid-template-columns: 1fr; }
    .seo-content { padding: 1.5rem 1.4rem; }
  }
</style>
