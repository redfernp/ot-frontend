---
import CouponRow from "@/components/CouponRow.astro";
import CategorySidebar from "@/components/CategorySidebar.astro";
import DateRail from "@/components/DateRail.astro";
import { getInternationalTips, type WpCategory, type WpPost } from "@/lib/graphql";
import { placeholderInternationalTips, placeholderRelatedTips } from "@/lib/relatedTips";
import { getCategorySeoCopy } from "@/lib/categorySeoCopy";
import { footballByRegion, footballPopularLeagues } from "@/lib/siteNav";
import { topDivisions } from "@/lib/topDivisions";

const topLeaguesSorted = [...topDivisions].sort((a, b) => a.league.localeCompare(b.league));

// Reads ACF Pro fields category_top_seo_text + category_bottom_seo_text from WP.
// Falls back to src/lib/categorySeoCopy for dev preview / unpopulated categories.
type CategoryWithSeo = WpCategory & {
  posts?: { nodes: WpPost[] };
  categoryTopSeoText?: {
    categoryTopSeoTextEditor?: string;
  };
  categoryBottomSeoText?: {
    categoryBottomSeoText?: string;
  };
};

type Props = {
  category: CategoryWithSeo;
};

const { category } = Astro.props;
const hasWpGraphQL = Boolean(import.meta.env.WPGRAPHQL_ENDPOINT);
const livePosts = category.posts?.nodes ?? [];
const posts = livePosts.length ? livePosts : hasWpGraphQL ? [] : placeholderRelatedTips;

const fallbackSeo = getCategorySeoCopy(category.slug);
const topSeo = category.categoryTopSeoText?.categoryTopSeoTextEditor || fallbackSeo.top || "";
const bottomSeo = category.categoryBottomSeoText?.categoryBottomSeoText || fallbackSeo.bottom || "";

const categoryName = category.name || "Football";

// Dynamic: today's top international matches.
// Local placeholders are used only when WPGraphQL is not configured.
const liveInternational = await getInternationalTips(6).catch(() => []);
const internationalPosts = liveInternational.length || !hasWpGraphQL
  ? (liveInternational.length ? liveInternational : placeholderInternationalTips)
  : [];

// Top inline league chips for the hero (popular subset, taken from real IA)
const heroLeagueChips = footballPopularLeagues.slice(0, 8);
---

<nav class="breadcrumbs" aria-label="Breadcrumb">
  <a href="/">Home</a>
  <span class="sep">/</span>
  <span aria-current="page">{categoryName}</span>
</nav>

<header class="hub-hero">
  <div class="hub-hero-inner">
    <p class="hero-eyebrow">Football 1x2 betting</p>
    <h1>{categoryName} 1x2 Betting Tips &amp; Predictions</h1>
    {topSeo ? (
      <div class="hub-lede" set:html={topSeo} />
    ) : category.description ? (
      <p class="hub-lede" set:html={category.description} />
    ) : (
      <p class="hub-lede">
        Looking for today's best Football 1x2 betting tips and predictions? Oddstips covers every major league, cup and international fixture with Bet365 odds, value angles and accumulator picks. Pick a league below or browse the latest predictions.
      </p>
    )}
    <ul class="hero-chips">
      {heroLeagueChips.map((link) => (
        <li><a href={link.path}>{link.label}</a></li>
      ))}
    </ul>
  </div>
  <div class="hub-hero-pattern" aria-hidden="true"></div>
</header>

<div class="hub-layout">
  <main class="hub-main">
    <DateRail />

    <section class="post-list internationals" aria-labelledby="internationals-heading" data-date-filter-section>
      <header class="post-list-head">
        <p class="eyebrow on-orange">International</p>
        <h2 id="internationals-heading">Top International Matches</h2>
        <p class="post-list-meta">
          <span data-date-count data-singular="match" data-plural="matches">
            {internationalPosts.length} {internationalPosts.length === 1 ? "match" : "matches"}
          </span>
        </p>
      </header>
      {internationalPosts.length > 0 ? (
        <div class="post-list-rows" data-date-filter-list>
          {internationalPosts.map((post) => <CouponRow post={post} />)}
        </div>
      ) : null}
      <p class="empty-state" data-date-empty hidden={internationalPosts.length > 0}>No international matches found for this date. Try another date.</p>
    </section>

    <section class="post-list" aria-labelledby="latest-football-heading" data-date-filter-section>
      <header class="post-list-head">
        <p class="eyebrow">All predictions</p>
        <h2 id="latest-football-heading">All The Latest Football Betting Predictions</h2>
        <p class="post-list-meta">
          <span data-date-count data-singular="tip" data-plural="tips">
            {posts.length} {posts.length === 1 ? "tip" : "tips"}
          </span>
        </p>
      </header>
      {posts.length > 0 ? (
        <div class="post-list-rows" data-date-filter-list>
          {posts.map((post) => <CouponRow post={post} />)}
        </div>
      ) : null}
      <p class="empty-state" data-date-empty hidden={posts.length > 0}>No football tips found for this date. Try another date.</p>
    </section>

    {bottomSeo && (
      <section class="seo-content" aria-label="Category guide">
        <div class="seo-prose" set:html={bottomSeo} />
      </section>
    )}

    <section class="by-region nav-block" aria-labelledby="by-region-heading">
      <p class="block-eyebrow">Every country covered</p>
      <h2 id="by-region-heading">Every Football Betting Tip By Country</h2>
      <div class="region-grid">
        <div>
          <h3>European Football Betting Tips</h3>
          <ul class="region-list">
            {footballByRegion.european.map((link) => (
              <li><a href={link.path}>{link.label}</a></li>
            ))}
          </ul>
        </div>
        <div>
          <h3>Americas Football Betting Tips</h3>
          <ul class="region-list">
            {footballByRegion.americas.map((link) => (
              <li><a href={link.path}>{link.label}</a></li>
            ))}
          </ul>
        </div>
        <div>
          <h3>Rest Of World Football Betting Tips</h3>
          <ul class="region-list">
            {footballByRegion.restOfWorld.map((link) => (
              <li><a href={link.path}>{link.label}</a></li>
            ))}
          </ul>
        </div>
      </div>
    </section>

    <section class="all-top-leagues nav-block" aria-labelledby="all-top-leagues-heading">
      <p class="block-eyebrow">Top flights</p>
      <h2 id="all-top-leagues-heading">All Top Leagues</h2>
      <p class="block-sub">The first-tier league for every country we cover. Pick a league for that division's tips.</p>
      <ul class="region-list top-leagues-list">
        {topLeaguesSorted.map((div) => (
          <li>
            <a href={div.leaguePath}>
              <span>{div.league}</span>
              <small>{div.country}</small>
            </a>
          </li>
        ))}
      </ul>
    </section>
  </main>

  <CategorySidebar currentPath={category.uri} />
</div>

<style>
  .breadcrumbs {
    color: var(--ot-muted);
    font-size: 0.85rem;
    margin-bottom: 1rem;
  }
  .breadcrumbs a { color: var(--ot-brand-blue); text-decoration: none; }
  .breadcrumbs a:hover { text-decoration: underline; }
  .breadcrumbs .sep { color: var(--ot-muted-2); margin: 0 0.35rem; }

  /* HERO */
  .hub-hero {
    background: linear-gradient(135deg, var(--ot-brand-blue) 0%, var(--ot-brand-blue-dark) 100%);
    border-radius: var(--ot-radius);
    color: #fff;
    margin-bottom: 1.5rem;
    overflow: hidden;
    position: relative;
  }
  .hub-hero-pattern {
    background:
      radial-gradient(circle at 18px 18px, rgba(255, 255, 255, 0.07) 1.2px, transparent 1.6px) 0 0 / 28px 28px,
      radial-gradient(900px 240px at 100% 0%, rgba(245, 99, 0, 0.35), transparent 60%);
    inset: 0;
    pointer-events: none;
    position: absolute;
    z-index: 0;
  }
  .hub-hero-inner {
    padding: 2.25rem 2rem 1.75rem;
    position: relative;
    z-index: 1;
  }
  .hub-hero h1 {
    color: #fff;
    font-size: clamp(1.85rem, 3.2vw, 2.5rem);
    line-height: 1.12;
    margin: 0 0 0.85rem;
    max-width: 28ch;
  }
  .hero-eyebrow {
    color: var(--ot-brand-orange);
    font-size: 0.72rem;
    font-weight: 900;
    letter-spacing: 0.12em;
    margin: 0 0 0.6rem;
    text-transform: uppercase;
  }
  .hub-lede {
    color: #d5e7f7;
    font-size: 1rem;
    line-height: 1.6;
    margin: 0 0 1.4rem;
    max-width: 64ch;
  }
  .hub-lede :global(p) {
    color: #d5e7f7;
    margin: 0 0 0.65rem;
  }
  .hub-lede :global(p:last-child) { margin-bottom: 0; }
  .hub-lede :global(a) {
    color: #fff;
    font-weight: 700;
    text-decoration: underline;
    text-decoration-color: rgba(255, 255, 255, 0.55);
  }
  .hub-lede :global(a:hover) {
    color: var(--ot-brand-orange);
    text-decoration-color: var(--ot-brand-orange);
  }
  .hub-lede :global(strong) { color: #fff; }
  .hero-chips {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    list-style: none;
    margin: 0;
    padding: 0;
  }
  .hero-chips a {
    background: rgba(255, 255, 255, 0.1);
    border: 1px solid rgba(255, 255, 255, 0.2);
    border-radius: 999px;
    color: #fff;
    display: inline-block;
    font-size: 0.82rem;
    font-weight: 700;
    padding: 0.35rem 0.85rem;
    text-decoration: none;
    transition: background 120ms ease, border-color 120ms ease;
  }
  .hero-chips a:hover {
    background: var(--ot-brand-orange);
    border-color: var(--ot-brand-orange);
  }

  .hub-layout {
    display: grid;
    gap: 1.5rem;
    grid-template-columns: minmax(0, 1fr) 300px;
  }

  .hub-main {
    display: grid;
    gap: 1.75rem;
    min-width: 0;
  }

  .section-head { margin-bottom: 1rem; }
  .section-head h2 {
    color: var(--ot-text);
    font-size: clamp(1.3rem, 2.2vw, 1.6rem);
    margin: 0;
  }
  .section-sub {
    color: var(--ot-muted);
    font-size: 0.92rem;
    margin: 0.4rem 0 0;
    max-width: 60ch;
  }
  .block-eyebrow {
    color: var(--ot-brand-blue);
    font-size: 0.72rem;
    font-weight: 900;
    letter-spacing: 0.1em;
    margin: 0 0 0.3rem;
    text-transform: uppercase;
  }

  /* POST LIST */
  .post-list {
    background: var(--ot-surface);
    border: 1px solid var(--ot-border);
    border-radius: var(--ot-radius);
    box-shadow: var(--ot-shadow-sm);
    overflow: hidden;
  }
  .post-list-head {
    align-items: end;
    background: linear-gradient(180deg, #f3f8fd 0%, #ffffff 100%);
    border-bottom: 1px solid var(--ot-border);
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem 1rem;
    justify-content: space-between;
    padding: 1.1rem 1.25rem;
  }
  .post-list-head .eyebrow {
    color: var(--ot-brand-blue);
    font-size: 0.7rem;
    font-weight: 900;
    letter-spacing: 0.1em;
    margin: 0;
    text-transform: uppercase;
    width: 100%;
  }
  .post-list-head .eyebrow.on-orange { color: var(--ot-brand-orange); }
  .post-list-head h2 {
    color: var(--ot-text);
    font-size: 1.15rem;
    margin: 0.2rem 0 0;
  }
  .post-list-meta {
    color: var(--ot-muted);
    font-size: 0.8rem;
    margin: 0;
  }

  .internationals {
    border-top: 4px solid var(--ot-brand-orange);
  }
  .empty-state {
    color: var(--ot-muted);
    font-size: 0.95rem;
    margin: 0;
    padding: 1.5rem 1.25rem;
  }

  /* NAV BLOCK (reused for region grid) */
  .nav-block {
    background: var(--ot-surface);
    border: 1px solid var(--ot-border);
    border-radius: var(--ot-radius);
    box-shadow: var(--ot-shadow-sm);
    padding: 1.25rem 1.4rem;
  }
  .nav-block h2 {
    color: var(--ot-text);
    font-size: 1.25rem;
    margin: 0 0 1rem;
  }

  /* SEO CONTENT */
  .seo-content {
    background: var(--ot-surface);
    border: 1px solid var(--ot-border);
    border-radius: var(--ot-radius);
    box-shadow: var(--ot-shadow-sm);
    padding: 1.75rem 1.75rem 2rem;
  }
  .seo-prose {
    color: var(--ot-text);
    font-size: 1rem;
    line-height: 1.7;
    max-width: 70ch;
  }
  .seo-prose :global(h2) {
    border-bottom: 2px solid var(--ot-brand-blue-soft);
    color: var(--ot-brand-blue-dark);
    font-size: 1.25rem;
    margin: 2rem 0 0.85rem;
    padding-bottom: 0.4rem;
  }
  .seo-prose :global(h2:first-child) { margin-top: 0; }
  .seo-prose :global(h3) {
    color: var(--ot-brand-blue-dark);
    font-size: 1.1rem;
    margin: 1.5rem 0 0.6rem;
  }
  .seo-prose :global(p) {
    color: var(--ot-text-2);
    margin: 0 0 1rem;
  }
  .seo-prose :global(strong) { color: var(--ot-text); }
  .seo-prose :global(a) {
    color: var(--ot-brand-blue);
    font-weight: 700;
    text-decoration: underline;
    text-decoration-color: var(--ot-brand-blue-soft);
    text-underline-offset: 3px;
  }
  .seo-prose :global(a:hover) {
    color: var(--ot-brand-blue-dark);
    text-decoration-color: var(--ot-brand-blue);
  }
  .seo-prose :global(ul),
  .seo-prose :global(ol) {
    margin: 0 0 1.25rem;
    padding-left: 1.4rem;
  }
  .seo-prose :global(ul) { list-style: none; padding-left: 0; }
  .seo-prose :global(ul li) {
    color: var(--ot-text-2);
    padding: 0.2rem 0 0.2rem 1.6rem;
    position: relative;
  }
  .seo-prose :global(ul li)::before {
    background: var(--ot-brand-orange);
    border-radius: 999px;
    content: "";
    height: 7px;
    left: 0.3rem;
    position: absolute;
    top: 0.85rem;
    width: 7px;
  }
  .seo-prose :global(ol) {
    counter-reset: seo-counter;
    list-style: none;
    padding-left: 0;
  }
  .seo-prose :global(ol li) {
    color: var(--ot-text-2);
    counter-increment: seo-counter;
    padding: 0.4rem 0 0.4rem 2.2rem;
    position: relative;
  }
  .seo-prose :global(ol li)::before {
    background: var(--ot-brand-blue);
    border-radius: 6px;
    color: #fff;
    content: counter(seo-counter);
    font-size: 0.78rem;
    font-weight: 900;
    height: 22px;
    left: 0;
    line-height: 22px;
    position: absolute;
    text-align: center;
    top: 0.45rem;
    width: 22px;
  }

  /* REGION GRID */
  .by-region .region-grid {
    display: grid;
    gap: 1.5rem;
    grid-template-columns: repeat(3, minmax(0, 1fr));
  }
  .by-region h3 {
    border-bottom: 2px solid var(--ot-brand-blue-soft);
    color: var(--ot-brand-blue-dark);
    font-size: 1rem;
    margin: 0 0 0.65rem;
    padding-bottom: 0.4rem;
  }
  .region-list {
    columns: 1;
    list-style: none;
    margin: 0;
    padding: 0;
  }
  .region-list li a {
    border-bottom: 1px solid var(--ot-border);
    color: var(--ot-brand-blue);
    display: block;
    font-size: 0.88rem;
    padding: 0.4rem 0;
    text-decoration: none;
  }
  .region-list li:last-child a { border-bottom: 0; }
  .region-list li a:hover {
    color: var(--ot-brand-blue-dark);
    text-decoration: underline;
  }

  /* ALL TOP LEAGUES */
  .all-top-leagues .block-sub {
    color: var(--ot-muted);
    font-size: 0.92rem;
    margin: 0 0 1.1rem;
    max-width: 60ch;
  }
  .top-leagues-list {
    column-count: 3;
    column-gap: 1.5rem;
  }
  .top-leagues-list li {
    break-inside: avoid;
  }
  .top-leagues-list li a {
    align-items: baseline;
    display: flex;
    gap: 0.4rem;
    justify-content: space-between;
    padding: 0.5rem 0;
  }
  .top-leagues-list li a span {
    color: var(--ot-brand-blue);
    font-size: 0.92rem;
    font-weight: 700;
  }
  .top-leagues-list li a small {
    color: var(--ot-muted);
    font-size: 0.72rem;
    font-weight: 800;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    white-space: nowrap;
  }
  .top-leagues-list li a:hover span { color: var(--ot-brand-blue-dark); text-decoration: underline; }
  .top-leagues-list li a:hover small { color: var(--ot-brand-orange); }

  @media (max-width: 1024px) {
    .by-region .region-grid { grid-template-columns: repeat(2, 1fr); }
    .top-leagues-list { column-count: 2; }
  }
  @media (max-width: 880px) {
    .hub-layout { grid-template-columns: 1fr; }
    .by-region .region-grid { grid-template-columns: 1fr; }
    .top-leagues-list { column-count: 1; }
    .hub-hero-inner { padding: 1.75rem 1.5rem 1.5rem; }
    .seo-content { padding: 1.5rem 1.4rem; }
  }
</style>
